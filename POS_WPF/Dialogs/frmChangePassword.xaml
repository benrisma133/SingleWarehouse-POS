<Window x:Class="POS_WPF.Dialogs.frmChangePassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POS_WPF.Controls"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420" SizeToContent="Height">

    <Window.Resources>
        <Style x:Key="OrangeBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10" Padding="0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF8C42" Offset="0"/>
                                    <GradientStop Color="#e06b1f" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF8C42" BlurRadius="14"
                                                  ShadowDepth="0" Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10"
                                Background="#F4F6FA"
                                Padding="0,12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E8ECF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="White" Padding="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                              Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <!-- Drag support -->
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick"
                          Command="{x:Null}"/>
        </Border.InputBindings>

        <StackPanel>

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="34" Height="34" CornerRadius="10"
                                Background="#FFF3EA" Margin="0,0,12,0">
                            <TextBlock Text="🔑" FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Change Password"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#1A1D23" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Enter your current password then choose a new one."
                               FontSize="12" Foreground="#9099A8"
                               FontFamily="Segoe UI" Margin="46,0,0,0"/>
                </StackPanel>

                <!-- Close X -->
                <Button Grid.Column="1"
                        Width="30" Height="30"
                        VerticalAlignment="Top"
                        Click="BtnCancel_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="8"
                                    Background="Transparent">
                                <TextBlock Text="✕" FontSize="13"
                                           Foreground="#9099A8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#FFE5E5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Error banner -->
            <Border x:Name="ErrorBanner"
                    CornerRadius="10" Background="#FFF0F0"
                    BorderBrush="#F05454" BorderThickness="1"
                    Padding="14,10" Margin="0,0,0,16"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ErrorText"
                               FontSize="12.5" Foreground="#C0392B"
                               FontFamily="Segoe UI" TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Current password -->
            <TextBlock Text="CURRENT PASSWORD"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#9099A8" FontFamily="Segoe UI"
                       Margin="0,0,0,6"/>
            <controls:ModernPasswordInput
                x:Name="TxtOldPassword"
                Placeholder="Enter your current password"
                IsRequired="True"
                MinLength="1"
                Margin="0,0,0,16"/>

            <!-- Divider -->
            <Border Height="1" Background="#F0F2F7" Margin="0,0,0,16"/>

            <!-- New password -->
            <TextBlock Text="NEW PASSWORD"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#9099A8" FontFamily="Segoe UI"
                       Margin="0,0,0,6"/>
            <controls:ModernPasswordInput
                x:Name="TxtNewPassword"
                Placeholder="Enter new password"
                IsRequired="True"
                MinLength="5"
                Margin="0,0,0,16"/>

            <!-- Confirm new password -->
            <TextBlock Text="CONFIRM NEW PASSWORD"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#9099A8" FontFamily="Segoe UI"
                       Margin="0,0,0,6"/>
            <controls:ModernPasswordInput
                x:Name="TxtConfirmPassword"
                Placeholder="Repeat new password"
                IsRequired="True"
                MinLength="5"
                Margin="0,0,0,24"/>

            <!-- Strength hint -->
            <Border CornerRadius="10" Background="#FFF3EA"
                    Padding="12,10" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💡" FontSize="13"
                               VerticalAlignment="Top" Margin="0,0,10,0"/>
                    <TextBlock FontSize="11.5" Foreground="#9099A8"
                               FontFamily="Segoe UI" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Foreground="#FF8C42" Text="Tip: "/>
                        <Run Text="Use at least 6 characters. Mix letters, numbers and symbols for a stronger password."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource CancelBtn}"
                        Content="Cancel"
                        Click="BtnCancel_Click"/>

                <Button Grid.Column="2"
                        Style="{StaticResource OrangeBtn}"
                        Content="Update Password"
                        Click="BtnConfirm_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>