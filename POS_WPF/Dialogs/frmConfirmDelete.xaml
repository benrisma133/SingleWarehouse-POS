<Window x:Class="POS_WPF.Dialogs.frmConfirmDelete"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420" SizeToContent="Height">

    <Border CornerRadius="8" Background="#FFF0F0"
            BorderBrush="#F05454" BorderThickness="1.2"
            Padding="12,10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                              Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <StackPanel>

            <!-- ── Header ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="⚠️" FontSize="14"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTitle"
                           FontSize="11.5" FontWeight="Bold"
                           Foreground="#F05454" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ── Divider ── -->
            <Border Height="1" Background="#FFCDD2" Margin="0,0,0,8"/>

            <!-- ── Message ── -->
            <TextBlock x:Name="TxtMessage"
                       FontSize="11.5" Foreground="#5C3333"
                       FontFamily="Segoe UI"
                       TextWrapping="Wrap"
                       FontStyle="Italic"/>

            <!-- ── Buttons ── -->
            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,10,0,0">

                <!-- Cancel -->
                <Button Click="BtnCancel_Click"
            Background="#E0E0E0"
            Foreground="#555555"
            Padding="10,4"
            Margin="0,0,6,0"
            Cursor="Hand"
            BorderThickness="0"
            FontSize="11"
            FontFamily="Segoe UI"
            FontWeight="SemiBold">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="10,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                    Cancel
                </Button>

                <!-- Delete Anyway -->
                <Button Click="BtnDeleteAnyway_Click"
                        Background="#F05454"
                        Foreground="White"
                        Padding="10 ,10"
                        Cursor="Hand"
                        BorderThickness="0"
                        FontSize="11"
                        FontFamily="Segoe UI"
                        FontWeight="SemiBold">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="10,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                    Delete Anyway
                </Button>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>