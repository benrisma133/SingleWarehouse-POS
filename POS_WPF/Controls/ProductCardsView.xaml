<UserControl x:Class="POS_WPF.Controls.ProductCardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:POS_WPF.Controls">

    <Border Padding="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================= FILTER BAR ================= -->
            <Border Background="#FFFFFF"
                    CornerRadius="14"
                    Padding="18"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Product -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Product"
                                   FontSize="13"
                                   Foreground="#777"
                                   Margin="4,0,0,4"/>
                        <ComboBox x:Name="cbProducts"
                                  Height="36"/>
                    </StackPanel>

                    <!-- Warehouse -->
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Warehouse"
                                   FontSize="13"
                                   Foreground="#777"
                                   Margin="4,0,0,4"/>
                        <ComboBox x:Name="cbWarehouses"
                                  Height="36"/>
                    </StackPanel>

                    <!-- ADD BUTTON -->
                    <Button Grid.Column="3"
                            Padding="20,0"
                            Content="+ Add New"
                            FontWeight="Bold"
                            Background="#E5C95F"
                            Foreground="#2C2C2C"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,20,0,0" Height="36" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>

            <!-- ================= CARDS ================= -->
            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0"
                          VerticalScrollBarVisibility="Auto">

                <WrapPanel x:Name="CardsPanel"
                           Orientation="Horizontal"
                           ItemWidth="520"/>
            </ScrollViewer>

        </Grid>

    </Border>
</UserControl>
