                                    <TextBlock Canvas.Left="203" Canvas.Top="163" Text="$$$" FontSize="7" FontWeight="Bold" FontFamily="Segoe UI" Foreground="#FF8C42"/>
                                    <Rectangle Canvas.Left="164" Canvas.Top="183" Width="66" Height="5" RadiusX="2" RadiusY="2" Fill="#444444"/>
                                    <Rectangle Canvas.Left="160" Canvas.Top="187" Width="74" Height="14" RadiusX="4" RadiusY="4" Fill="#333333" Stroke="#FF8C42" StrokeThickness="1.5"/>
                                    <Rectangle Canvas.Left="164" Canvas.Top="191" Width="50" Height="1.5" RadiusX="0.75" RadiusY="0.75" Fill="#FF8C42" Opacity="0.3"/>
                                    <Rectangle Canvas.Left="164" Canvas.Top="195" Width="50" Height="1.5" RadiusX="0.75" RadiusY="0.75" Fill="#FF8C42" Opacity="0.3"/>
                                    <Rectangle Canvas.Left="186" Canvas.Top="190" Width="20" Height="8" RadiusX="2" RadiusY="2" Fill="#444444" Stroke="#FF8C42" StrokeThickness="0.8" Opacity="0.7"/>
                                    <Rectangle Canvas.Left="78"  Canvas.Top="208" Width="3"  Height="18" Fill="White" Opacity="0.8"/>
