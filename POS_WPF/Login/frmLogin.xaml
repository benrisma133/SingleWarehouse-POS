                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1D23" Offset="0"/>
                        <GradientStop Color="#23262F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Decorative orange circles -->
                    <Ellipse Width="320" Height="320"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Margin="-100,-100,0,0"
                             Opacity="0.06">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF8C42" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
