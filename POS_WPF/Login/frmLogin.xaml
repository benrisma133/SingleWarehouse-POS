                                    <Rectangle Canvas.Left="44" Canvas.Top="192" Width="14" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="#FF8C42" Opacity="0.7"/>
                                    <Rectangle Canvas.Left="166" Canvas.Top="140" Width="62" Height="44" RadiusX="5" RadiusY="5" Stroke="#FF8C42" StrokeThickness="2">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3a3a3a" Offset="0"/>
                                                <GradientStop Color="#2a2a2a" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle Canvas.Left="170" Canvas.Top="144" Width="54" Height="36" RadiusX="3" RadiusY="3" Fill="#111111"/>
                                    <Rectangle Canvas.Left="170" Canvas.Top="144" Width="54" Height="10" RadiusX="3" RadiusY="3" Fill="#FF8C42" Opacity="0.7"/>
                                    <Rectangle Canvas.Left="170" Canvas.Top="150" Width="54" Height="4" Fill="#FF8C42" Opacity="0.7"/>
                                    <Rectangle Canvas.Left="173" Canvas.Top="158" Width="20" Height="2" RadiusX="1" RadiusY="1" Fill="#FF8C42" Opacity="0.7"/>
                                    <Rectangle Canvas.Left="173" Canvas.Top="163" Width="30" Height="2" RadiusX="1" RadiusY="1" Fill="#888888" Opacity="0.5"/>
