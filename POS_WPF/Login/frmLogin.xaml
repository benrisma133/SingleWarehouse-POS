                                    <Rectangle Canvas.Left="96"  Canvas.Top="208" Width="3"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="101" Canvas.Top="208" Width="1"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="104" Canvas.Top="208" Width="4"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="110" Canvas.Top="208" Width="2"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="114" Canvas.Top="208" Width="3"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="119" Canvas.Top="208" Width="1"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="122" Canvas.Top="208" Width="4"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="128" Canvas.Top="208" Width="2"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="132" Canvas.Top="208" Width="3"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="137" Canvas.Top="208" Width="1"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="140" Canvas.Top="208" Width="4"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="146" Canvas.Top="208" Width="2"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="150" Canvas.Top="208" Width="3"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="155" Canvas.Top="208" Width="2"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="159" Canvas.Top="208" Width="4"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="165" Canvas.Top="208" Width="1"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="168" Canvas.Top="208" Width="3"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="173" Canvas.Top="208" Width="2"  Height="18" Fill="White" Opacity="0.8"/>
                                    <Rectangle Canvas.Left="177" Canvas.Top="208" Width="4"  Height="18" Fill="White" Opacity="0.8"/>
                                    <TextBlock Canvas.Left="60" Canvas.Top="232" Text="TECH  POS" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI" Foreground="#FF8C42"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <!-- App Name -->
                        <TextBlock FontSize="30" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="White"
                                   Margin="0,0,0,6"
                                   LineHeight="34">
                            <Run Text="Point"/>
                            <Run Text=" of " Foreground="#9099A8"/>
                            <Run Text="Sales"/>
                        </TextBlock>

                        <!-- Accent underline -->
                        <Border Width="48" Height="3"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF8C42" Offset="0"/>
                                    <GradientStop Color="#e06b1f" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Subtitle -->
                        <TextBlock FontSize="13.5"
                                   Foreground="#9099A8"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   MaxWidth="300"
                                   Text="Manage sales of devices and accessories with ease and efficiency."/>

                        <!-- Feature pills -->
                        <StackPanel Margin="0,28,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="#FF8C42"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Real-time inventory tracking"
                                           FontSize="12.5" Foreground="#C0C7D4"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="#FF8C42"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Multi-client sales management"
                                           FontSize="12.5" Foreground="#C0C7D4"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="#FF8C42"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Detailed sales history &amp; reports"
                                           FontSize="12.5" Foreground="#C0C7D4"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
