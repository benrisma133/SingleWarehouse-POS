                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════
                     RIGHT — Login Form Panel
                 ══════════════════════════════════════ -->
            <Border Grid.Column="1"
                    Background="#F4F6FA"
                    CornerRadius="0,20,20,0">

                <!-- Close button -->
                <Grid>
                    <Button x:Name="BtnClose"
                            Width="32" Height="32"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            Cursor="Hand"
                            Click="BtnClose_Click"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBg"
                                        Background="Transparent"
                                        CornerRadius="8">
                                    <TextBlock Text="✕"
                                               FontSize="13"
                                               Foreground="#9099A8"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBg" Property="Background" Value="#FFE5E5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Form content -->
                    <StackPanel VerticalAlignment="Center"
                                Margin="50,0,50,0">

                        <!-- Greeting -->
                        <TextBlock Text="Welcome back 👋"
                                   FontSize="24" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="#1A1D23"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Sign in to your account to continue"
                                   FontSize="13" Foreground="#9099A8"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,36"/>

                        <!-- Error message banner (hidden by default) -->
                        <Border x:Name="ErrorBanner"
                                CornerRadius="10"
                                Background="#FFF0F0"
                                BorderBrush="#F05454"
                                BorderThickness="1"
                                Padding="14,10"
                                Margin="0,0,0,18"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="ErrorText"
                                           FontSize="12.5"
                                           Foreground="#C0392B"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="Invalid username or password."/>
                            </StackPanel>
                        </Border>

                        <!-- Username -->
                        <controls:ModernInput
                            x:Name="TxtUsername"
                            Label="Username"
                            Placeholder="Enter your username"
                            IsRequired="True"
                            ValidationType="AlphaNumeric"
                            BorderRadius="10"
                            MinLength="2"
                            Margin="0,0,0,18"/>

                        <!-- Password -->
                        <controls:ModernPasswordInput
                            x:Name="TxtPassword"
                            Label="Password"
                            Placeholder="Enter your password"
                            IsRequired="True"
                            MinLength="5"
                            Margin="0,0,0,20"/>

                        <!-- Remember me row -->
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      x:Name="ChkRememberMe"
                                      Style="{StaticResource ModernCheckBox}"
                                      VerticalAlignment="Center"
                                      Checked="ChkRememberMe_Checked"
                                      Unchecked="ChkRememberMe_Unchecked">
                                <TextBlock Text="Remember me"
                                           FontSize="12.5"
                                           Foreground="#4A5060"
                                           FontFamily="Segoe UI"/>
                            </CheckBox>

                        </Grid>

                        <!-- Login Button -->
                        <Button x:Name="BtnLogin"
                                Style="{StaticResource LoginBtn}"
