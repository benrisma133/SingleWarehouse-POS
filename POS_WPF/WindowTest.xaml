<Window x:Class="POS_WPF.WindowTest"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POS_WPF"
        xmlns:controls="clr-namespace:POS_WPF.Controls"
        mc:Ignorable="d"
        Title="Device Brands Gallery" Height="800" Width="650">

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center">
            <TextBlock Text="Toggle Test" 
                       FontSize="16" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- Toggle button will be added here from code-behind -->
            <StackPanel x:Name="ToggleContainer" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center"/>

            <TextBlock x:Name="StatusText" 
                       Text="Status: Inactive" 
                       FontSize="14"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>