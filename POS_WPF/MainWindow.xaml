                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- Profile Section -->
                <!-- Profile Section at the Bottom -->
                <Border x:Name="ProfileBorder" MouseEnter="ProfileBorder_MouseEnter"
                        MouseLeave="ProfileBorder_MouseLeave"  Style="{StaticResource ProfileBorderStyle}" MouseLeftButtonUp="ProfileBorder_Click" VerticalAlignment="Bottom" Background="#4A4A4A" Height="60" Margin="10,0,10,10" CornerRadius="8"  Grid.Row="2" Cursor="Hand">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Profile Icon -->
                        <Viewbox x:Name="ProfileIcon" Width="50" Height="50" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#F5F5F5"
                              Data="M16.5 7.063C16.5 10.258 14.57 13 12 13c-2.572 0-4.5-2.742-4.5-5.938C7.5 3.868 9.16 2 12 2s4.5 1.867 4.5 5.063zM4.102 20.142C4.487 20.6 6.145 22 12 22c5.855 0 7.512-1.4 7.898-1.857a.416.416 0 0 0 .09-.317C19.9 18.944 19.106 15 12 15s-7.9 3.944-7.989 4.826a.416.416 0 0 0 .091.317z"/>
                            </Canvas>
                        </Viewbox>

                        <!-- Profile Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0" x:Name="ProfileTextStack">
