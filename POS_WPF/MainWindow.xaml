                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid x:Name="MainContent"  Margin="280,0,0,0" Background="#F5F5F5">
            <TextBlock x:Name="MainTitle" Text="Main Content Area"
                       FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#333"/>
        </Grid>
    
    
    </Grid>
</Window>
