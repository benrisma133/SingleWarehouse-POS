<Window x:Class="POS_WPF.Popup.ProductNotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="460" Height="540"
        ShowInTaskbar="False">

    <Window.Resources>

        <Style x:Key="InfoRowLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="InfoRowValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- No overlay — just the floating card centered in a transparent window -->
    <Grid>

        <Border x:Name="CardRoot"
                Background="White"
                CornerRadius="20"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0">

            <Border.Effect>
                <DropShadowEffect BlurRadius="35"
                                  ShadowDepth="6"
                                  Direction="270"
                                  Color="#000000"
                                  Opacity="0.18"/>
            </Border.Effect>

            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="0.88" ScaleY="0.88"/>
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>

            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CardScale"
                                             Storyboard.TargetProperty="ScaleX"
                                             From="0.88" To="1"
                                             Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="CardScale"
                                             Storyboard.TargetProperty="ScaleY"
                                             From="0.88" To="1"
                                             Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="CardRoot"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0" To="1"
                                             Duration="0:0:0.22"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ══════════ HEADER ══════════ -->
                <Border Grid.Row="0"
                        CornerRadius="20,20,0,0"
                        Padding="22,18,18,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF8C42" Offset="0"/>
                            <GradientStop Color="#E8621A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="50" Height="50"
                                CornerRadius="14"
                                Background="#33FFFFFF"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderIcon"
                                       Text="📦"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtProductName"
                                       Text="Product Name"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       FontFamily="Segoe UI"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="TxtTagLabel"
                                       Text="Out of Stock"
                                       FontSize="11"
                                       Foreground="#FFE0C8"
                                       FontFamily="Segoe UI"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource CloseBtn}"
                                VerticalAlignment="Top"
                                Click="CloseBtn_Click">
                            <TextBlock Text="✕"
                                       FontSize="14"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ══════════ BODY ══════════ -->
                <StackPanel Grid.Row="1" Margin="22,18,22,8">

                    <Border x:Name="StatusBadge"
                            CornerRadius="10"
                            Padding="14,9"
                            Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="BadgeDot"
                                     Width="8" Height="8"
                                     VerticalAlignment="Center"
                                     Margin="0,0,9,0"/>
                            <TextBlock x:Name="TxtSubText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Category"
                                       Style="{StaticResource InfoRowLabel}"/>
                            <TextBlock x:Name="TxtCategory"
                                       Text="—"
                                       Style="{StaticResource InfoRowValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0">
                            <TextBlock Text="Price"
                                       Style="{StaticResource InfoRowLabel}"/>
                            <TextBlock x:Name="TxtPrice"
                                       Text="—"
                                       Style="{StaticResource InfoRowValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Quantity"
                                       Style="{StaticResource InfoRowLabel}"/>
                            <TextBlock x:Name="TxtQuantity"
                                       Text="—"
                                       Style="{StaticResource InfoRowValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock Text="Notified"
                                       Style="{StaticResource InfoRowLabel}"/>
                            <TextBlock x:Name="TxtDate"
                                       Text="—"
                                       Style="{StaticResource InfoRowValue}"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1"
                            Background="#F0F0F0"
                            Margin="0,18,0,14"/>

                    <TextBlock Text="Description"
                               Style="{StaticResource InfoRowLabel}"/>
                    <TextBlock x:Name="TxtDescription"
                               Text="—"
                               FontSize="13"
                               Foreground="#4B5563"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               Margin="0,4,0,8"/>
                </StackPanel>

                <!-- ══════════ FOOTER ══════════ -->
                <Border Grid.Row="2"
                        Background="#FAFAFA"
                        CornerRadius="0,0,20,20"
                        Padding="22,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtFooterNote"
                                   Grid.Column="0"
                                   Text="Marked as read."
                                   FontSize="11"
                                   Foreground="#9CA3AF"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Got it"
                                Click="CloseBtn_Click"
                                Cursor="Hand"
                                Width="90" Height="34"
                                FontSize="13"
                                FontWeight="SemiBold"
                                FontFamily="Segoe UI"
                                Foreground="White">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btn" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF8C42" Offset="0"/>
                                                <GradientStop Color="#E8621A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btn" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btn" Property="Opacity" Value="0.70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>