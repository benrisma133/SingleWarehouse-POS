<Window x:Class="POS_WPF.ModernPasswordInputDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POS_WPF.Controls"
        Title="Modern Password Input Demo" 
        Height="450" Width="500"
        Background="#F9FAFB">

    <Grid Margin="40">
        <StackPanel>

            <TextBlock Text="Modern Password Input Examples" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,0,0,20"/>

            <!-- Basic Password Input -->
            <controls:ModernPasswordInput 
                x:Name="BasicPassword"
                Label="Password"
                Placeholder="Enter your password"
                IsRequired="True"
                MinLength="6"/>

            <!-- Password with custom validation -->
            <controls:ModernPasswordInput 
                x:Name="StrongPassword"
                Label="Strong Password"
                Placeholder="Must contain uppercase, lowercase, number"
                IsRequired="True"
                MinLength="8"
                MaxLength="20"/>

            <!-- Confirm Password -->
            <controls:ModernPasswordInput 
                x:Name="ConfirmPassword"
                Label="Confirm Password"
                Placeholder="Re-enter your password"
                IsRequired="True"/>

            <!-- Submit Button -->
            <Button Content="Submit" 
                    Height="44"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="Medium"
                    Cursor="Hand"
                    Click="SubmitButton_Click"
                    Margin="0,10,0,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Result Message -->
            <TextBlock x:Name="ResultMessage"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>

        </StackPanel>
    </Grid>


</Window>
