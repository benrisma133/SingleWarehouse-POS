<Window x:Class="POS_WPF.Serie.frmAddEditSerie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POS_WPF.Controls"
        xmlns:svg="http://sharpvectors.codeplex.com/runtime"
        Title="Serie"
        Width="540"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        AllowsTransparency="True">

    <Window.Resources>

        <!-- Message Box Styles -->
        <Style x:Key="MessageBox" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="ErrorBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background" Value="#D1FAE5"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F2F4F8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1E5EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C9D1DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Style -->
        <Style x:Key="IconStyle" TargetType="Path">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="#4A4A4A"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <!-- Rounded TextBox -->
        <Style x:Key="RoundedInput" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Margin" Value="0 10 0 10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sweet Button -->
        <Style x:Key="SweetButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Background" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Multi Select Combo Header -->
        <Style x:Key="MultiSelectCombo" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="10,0"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Smooth Tooltip Style -->
        <Style x:Key="SmoothToolTip" TargetType="ToolTip">
            <!-- SHOW FAST -->
            <Setter Property="ToolTipService.InitialShowDelay" Value="100"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
            <Setter Property="ToolTipService.ShowDuration" Value="1000"/>

            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                CornerRadius="6"
                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <EventTrigger RoutedEvent="ToolTip.Opened">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- FAST but SMOOTH -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>



    </Window.Resources>

    <Grid Margin="8">
        <Border CornerRadius="16"
                Background="White"
                BorderBrush="#DDE1E8"
                BorderThickness="1"
                SnapsToDevicePixels="True"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="10"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid Margin="1,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border CornerRadius="16,16,0,0" Background="#5E5E5E" Grid.Row="0" MouseDown="Header_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">

                            <!-- Serie Icon -->
                            <Viewbox Width="20"
                                     Height="20"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center">
                                <Path Fill="#FF8C42"
                                      Stretch="Uniform"
                                      Data="M3.05 4.75a.7.7 0 01.7-.7h3.5a.7.7 0 110 1.4h-3.5a.7.7 0 01-.7-.7z
                                            M3.75 7.05a.7.7 0 100 1.4h2.5a.7.7 0 100-1.4h-2.5z
                                            M0 3.25A2.25 2.25 0 012.25 1h6.5c.883 0 1.648.51 2.016 1.25h.984
                                            c.698 0 1.3.409 1.582 1h.918c.966 0 1.75.784 1.75 1.75v6
                                            a1.75 1.75 0 01-1.75 1.75h-.918c-.281.591-.884 1-1.582 1
                                            h-.984A2.25 2.25 0 018.75 15h-6.5A2.25 2.25 0 010 12.75v-9.5z
                                            M13.5 11.25h.75a.25.25 0 00.25-.25V5a.25.25 0 00-.25-.25h-.75v6.5z
                                            M11 12.25v-8.5h.75A.25.25 0 0112 4v8a.25.25 0 01-.25.25H11z
                                            M2.25 2.5a.75.75 0 00-.75.75v9.5c0 .414.336.75.75.75h6.5
                                            a.75.75 0 00.75-.75v-9.5a.75.75 0 00-.75-.75h-6.5z"/>
                            </Viewbox>

                            <!-- Title -->
                            <TextBlock x:Name="txtbTitle"
                                       Text="Add Serie"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F5F5"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="Close_Click"
                                Margin="6,10">
                            <Path Style="{StaticResource IconStyle}"
                                  Fill="#FF8C42"
                                  Data="M18.3 5.71L12 12l6.3 6.29-1.41 1.42L10.59 13.4l-6.3 6.31-1.41-1.42L9.17 12 2.88 5.71l1.41-1.42 6.3 6.3 6.29-6.3z"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Margin="40,25,40,0">

                        <TextBlock Text="Serie Information"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Please fill out all required fields"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,0,0,30"/>

                        <!-- Error Message -->
                        <Border x:Name="ErrorMessageBox"
                                Style="{StaticResource ErrorBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#DC2626"
                                           FontSize="14"
                                           Margin="0,0,0,6">
                                    ⚠️ Please fix the following errors:
                                </TextBlock>
                                <TextBlock x:Name="ErrorMessageText"
                                           Foreground="#991B1B"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Success Message -->
                        <Border x:Name="SuccessMessageBox"
                                Style="{StaticResource SuccessBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#059669"
                                           FontSize="14"
                                           Margin="0,0,0,6">
                                    ✓ Success!
                                </TextBlock>
                                <TextBlock Text="Form submitted successfully. All information has been validated."
                                           Foreground="#047857"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Serie Name Field -->
                        <controls:ModernInput x:Name="SerieName"
                                              Label="Serie Name"
                                              TextChanged="SerieNameInput_TextChanged"
                                              Placeholder="Enter the serie name"
                                              IsRequired="True"
                                              ValidationType="Name"
                                              BorderRadius="20"
                                              MinLength="2"
                                              Margin="0,0,0,20"/>

                        <!-- Brand ComboBox -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Brand"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <ComboBox x:Name="cmbBrand"
                                          Style="{StaticResource ModernComboBox}"
                                          ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                                          HorizontalAlignment="Left"
                                          Width="220"
                                          VerticalAlignment="Center"
                                          SelectedIndex="0"
                                          Cursor="Hand"
                                          SelectionChanged="cmbBrand_SelectionChanged">
                                    <!-- Items will be populated from code-behind -->
                                </ComboBox>
                                <Button x:Name="btnManageWarehouses"
                                        Width="40"
                                        Height="30"
                                        Margin="10,0,0,0"
                                        Background="#FF8C42"
                                        Foreground="White"
                                        Style="{StaticResource SweetButton}"
                                        ToolTipService.InitialShowDelay="50"
                                        ToolTipService.BetweenShowDelay="0"
                                        ToolTipService.ShowDuration="60000" Click="btnManageWarehouses_Click">

                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource SmoothToolTip}"
                                                 Content="Add brand"
                                                 Placement="Right"
                                                 HorizontalOffset="10"/>
                                    </Button.ToolTip>

                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Data="M12 5 L12 19 M5 12 L19 12"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                
                            </StackPanel>

                                
                        </StackPanel>

                        <!-- Serie Description -->
                        <controls:TextArea x:Name="SerieDescription"
                                           Label="Serie Description"
                                           Placeholder="Describe this serie..."
                                           HelperText="Write a brief description"
                                           MinLength="10"
                                           BorderRadius="20"
                                           MaxLength="100"
                                           AreaHeight="120"
                                           ShowCharacterCount="True"
                                           Margin="0,0,0,20"/>

                        
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <!-- Clear / Cancel -->
                    <Button Width="130"
                            Height="42"
                            Background="#5E5E5E"
                            Style="{StaticResource SweetButton}"
                            Click="Cancel_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource IconStyle}"
                                  Fill="White"
                                  Data="M16 29c-7.18 0-13-5.82-13-13s5.82-13 13-13 13 5.82 13 13-5.82 13-13 13zM16 6c-5.522 0-10 4.478-10 10s4.478 10 10 10c5.523 0 10-4.478 10-10s-4.477-10-10-10zM20.537 19.535l-1.014 1.014c-0.186 0.186-0.488 0.186-0.675 0l-2.87-2.87-2.87 2.87c-0.187 0.186-0.488 0.186-0.675 0l-1.014-1.014c-0.186-0.186-0.186-0.488 0-0.675l2.871-2.869-2.871-2.87c-0.186-0.187-0.186-0.489 0-0.676l1.014-1.013c0.187-0.187 0.488-0.187 0.675 0l2.87 2.87 2.87-2.87c0.187-0.187 0.489-0.187 0.675 0l1.014 1.013c0.186 0.187 0.186 0.489 0 0.676l-2.871 2.87 2.871 2.869c0.186 0.187 0.186 0.49 0 0.675z"/>
                            <TextBlock Text="Clear"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Save -->
                    <Button Width="130"
                            Height="42"
                            Background="#FF8C42"
                            Margin="10,0,0,0"
                            Style="{StaticResource SweetButton}"
                            Click="Save_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource IconStyle}"
                                  Fill="White"
                                  Data="M18.1716 1C18.702 1 19.2107 1.21071 19.5858 1.58579L22.4142 4.41421C22.7893 4.78929 23 5.29799 23 5.82843V20C23 21.6569 21.6569 23 20 23H4C2.34315 23 1 21.6569 1 20V4C1 2.34315 2.34315 1 4 1H18.1716ZM4 3C3.44772 3 3 3.44772 3 4V20C3 20.5523 3.44772 21 4 21L5 21L5 15C5 13.3431 6.34315 12 8 12L16 12C17.6569 12 19 13.3431 19 15V21H20C20.5523 21 21 20.5523 21 20V6.82843C21 6.29799 20.7893 5.78929 20.4142 5.41421L18.5858 3.58579C18.2107 3.21071 17.702 3 17.1716 3H17V5C17 6.65685 15.6569 8 14 8H10C8.34315 8 7 6.65685 7 5V3H4ZM17 21V15C17 14.4477 16.5523 14 16 14L8 14C7.44772 14 7 14.4477 7 15L7 21L17 21ZM9 3H15V5C15 5.55228 14.5523 6 14 6H10C9.44772 6 9 5.55228 9 5V3Z"/>
                            <TextBlock Text="Save"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
