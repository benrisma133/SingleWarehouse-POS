<Window x:Class="POS_WPF.frmAddEditWarehouse"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POS_WPF.Controls"
        Title="Warehouse"
        Width="540"
        Height="630"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"  
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- Message Box Styles -->
        <Style x:Key="MessageBox" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="ErrorBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background" Value="#D1FAE5"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>


        <!-- Sweet Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F2F4F8"/>
            <!-- Sweet light color -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1E5EB"/>
                            </Trigger>
                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C9D1DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Style -->
        <Style x:Key="IconStyle" TargetType="Path">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="#4A4A4A"/>
            <Setter Property="Margin" Value="0 0 0 0"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <!-- Rounded TextBox -->
        <Style x:Key="RoundedInput" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Margin" Value="0 10 0 10"/>
            <!-- هنا ديال spacing -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sweet Button -->
        <Style x:Key="SweetButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Background" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <!-- STATES -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.85"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.7"/>
                                <Setter TargetName="border"
                                Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97"
                                                ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.4"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        
    
        <Border 
            CornerRadius="16" 
            Background="#F5F1F3" 
            BorderBrush="#CCC" 
            BorderThickness="1" 
            SnapsToDevicePixels="True"
            Padding="0">

        <Border.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="10"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
        </Border.Effect>


        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Content taller for textboxes -->
                <RowDefinition Height="70"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
                <Border CornerRadius="16,16,0,0" Background="#5E5E5E" Grid.Row="0" MouseDown="Header_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="15 0">

                            <Path Width="22"
                  Height="22"
                  Stretch="Uniform"
                  Fill="#FF8C42"
                  Data="M13.5,5c-0.0762,0.0003-0.1514-0.0168-0.22-0.05L7.5,2L1.72,4.93
                        C1.4632,5.0515,1.1565,4.9418,1.035,4.685
                        S1.0232,4.1215,1.28,4
                        L7.5,0.92L13.72,4
                        c0.2761,0.0608,0.4508,0.3339,0.39,0.61
                        C14.0492,4.8861,13.7761,5.0608,13.5,5z
                        M5,10H2v3h3V10z
                        M9,10H6v3h3V10z
                        M13,10h-3v3h3V10z
                        M11,6H8v3h3V6z
                        M7,6H4v3h3V6z"/>

                            <TextBlock x:Name="txtbTitle"
                       Margin="8 0 0 0"
                       Text="Add Warehouse"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="#F5F5F5"/>
                        </StackPanel>

                        <Button Grid.Column="1" Style="{StaticResource CloseButtonStyle}" Click="Close_Click" Margin="0,12,0,11" VerticalAlignment="Stretch">
                            <Path Style="{StaticResource IconStyle}" Fill="#FF8C42" Data="M18.3 5.71L12 12l6.3 6.29-1.41 1.42L10.59 13.4l-6.3 6.31-1.41-1.42L9.17 12 2.88 5.71l1.41-1.42 6.3 6.3 6.29-6.3z"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">

                    <!-- Content -->
                    <StackPanel Margin="40 25 40 0">


                        <TextBlock Text="Warehouse Information"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,10"/>


                        <TextBlock Text="Please fill out all required fields" 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   Margin="0,0,0,30"/>

                        <!-- Error Message -->
                        <Border x:Name="ErrorMessageBox" 
                                Style="{StaticResource ErrorBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" 
                                           Foreground="#DC2626" 
                                           FontSize="14"
                                           Margin="0,0,0,6">
                        ⚠️ Please fix the following errors:
                                </TextBlock>
                                <TextBlock x:Name="ErrorMessageText" 
                                           Foreground="#991B1B" 
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Success Message -->
                        <Border x:Name="SuccessMessageBox" 
                                Style="{StaticResource SuccessBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" 
                                           Foreground="#059669" 
                                           FontSize="14"
                                           Margin="0,0,0,6">
                        ✓ Success!
                                </TextBlock>
                                <TextBlock Text="Form submitted successfully. All information has been validated." 
                                           Foreground="#047857" 
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>


                        <!-- Warehouse Name Field -->
                        <controls:ModernInput x:Name="WarehouseName"
                                              Label="Category Name"
                                              TextChanged="WarehouseNameInput_TextChanged"
                                              Placeholder="Enter the warehouse name"
                                              IsRequired="True"
                                              ValidationType="Name"
                                              BorderRadius="20"
                                              MinLength="2"
                                              Margin="0,0,0,20"/>


                        <!-- Location Field -->
                        <controls:ModernInput x:Name="Location"
                                              Label="Location Name"
                                              TextChanged="LocationInput_TextChanged"
                                              Placeholder="Enter the location"
                                              IsRequired="True"
                                              ValidationType="Name"
                                              BorderRadius="20"
                                              MinLength="2"
                                              Margin="0,0,0,20"/>


                        <!-- Description Field -->
                        <controls:TextArea  x:Name="WarehouseDescription"
                                            Label="Warehouse Description"
                                            Placeholder="Describe this warehouse..."
                                            HelperText="Write a brief description (at least 20 characters)"
                                            MinLength="10"
                                            BorderRadius="20"
                                            MaxLength="100"
                                            AreaHeight="120"
                                            ShowCharacterCount="True"
                                            Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">



                            <!-- Color preview rectangle -->
                            <Rectangle x:Name="rectPreview"
                                       Width="60"
                                       Height="60"
                                       Stroke="Black"
                                       StrokeThickness="1"
                                       RadiusX="10"
                                       RadiusY="10"
                                       Margin="0,0,16,26"/>

                            <!-- Vertical sliders -->
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <!-- Red -->
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="R:" Width="20" VerticalAlignment="Center"/>
                                    <Slider x:Name="sliderR" Minimum="0" Maximum="255" Width="100" ValueChanged="Slider_ValueChanged"/>
                                    <TextBlock x:Name="txtR" Width="30" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Green -->
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="G:" Width="20" VerticalAlignment="Center"/>
                                    <Slider x:Name="sliderG" Minimum="0" Maximum="255" Width="100" ValueChanged="Slider_ValueChanged"/>
                                    <TextBlock x:Name="txtG" Width="30" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Blue -->
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="B:" Width="20" VerticalAlignment="Center"/>
                                    <Slider x:Name="sliderB" Minimum="0" Maximum="255" Width="100" ValueChanged="Slider_ValueChanged"/>
                                    <TextBlock x:Name="txtB" Width="30" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Hex output -->
                                <TextBox x:Name="txtSelectedColor" Width="150" Height="25" IsReadOnly="True" Margin="0,5,0,0"/>
                            </StackPanel>


                        </StackPanel>




                    </StackPanel>

                </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="2" Margin="0 0 20 0">

                <!-- Cancel -->
                <Button Width="130" Height="42" Background="#5E5E5E" Style="{StaticResource SweetButton}" Click="Button_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconStyle}" Fill="White" Data="M16 29c-7.18 0-13-5.82-13-13s5.82-13 13-13 13 5.82 13 13-5.82 13-13 13zM16 6c-5.522 0-10 4.478-10 10s4.478 10 10 10c5.523 0 10-4.478 10-10s-4.477-10-10-10zM20.537 19.535l-1.014 1.014c-0.186 0.186-0.488 0.186-0.675 0l-2.87-2.87-2.87 2.87c-0.187 0.186-0.488 0.186-0.675 0l-1.014-1.014c-0.186-0.186-0.186-0.488 0-0.675l2.871-2.869-2.871-2.87c-0.186-0.187-0.186-0.489 0-0.676l1.014-1.013c0.187-0.187 0.488-0.187 0.675 0l2.87 2.87 2.87-2.87c0.187-0.187 0.489-0.187 0.675 0l1.014 1.013c0.186 0.187 0.186 0.489 0 0.676l-2.871 2.87 2.871 2.869c0.186 0.187 0.186 0.49 0 0.675z"/>
                        <TextBlock Text="Cancel" Margin="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Save -->
                <Button Width="130" Height="42" Background="#FF8C42" Margin="10 0 0 0" Style="{StaticResource SweetButton}" Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconStyle}" Fill="White" Data="M18.1716 1C18.702 1 19.2107 1.21071 19.5858 1.58579L22.4142 4.41421C22.7893 4.78929 23 5.29799 23 5.82843V20C23 21.6569 21.6569 23 20 23H4C2.34315 23 1 21.6569 1 20V4C1 2.34315 2.34315 1 4 1H18.1716ZM4 3C3.44772 3 3 3.44772 3 4V20C3 20.5523 3.44772 21 4 21L5 21L5 15C5 13.3431 6.34315 12 8 12L16 12C17.6569 12 19 13.3431 19 15V21H20C20.5523 21 21 20.5523 21 20V6.82843C21 6.29799 20.7893 5.78929 20.4142 5.41421L18.5858 3.58579C18.2107 3.21071 17.702 3 17.1716 3H17V5C17 6.65685 15.6569 8 14 8H10C8.34315 8 7 6.65685 7 5V3H4ZM17 21V15C17 14.4477 16.5523 14 16 14L8 14C7.44772 14 7 14.4477 7 15L7 21L17 21ZM9 3H15V5C15 5.55228 14.5523 6 14 6H10C9.44772 6 9 5.55228 9 5V3Z"/>
                        <TextBlock Text="Save" Margin="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

        </Grid>
    </Border>


    </Grid>

</Window>
