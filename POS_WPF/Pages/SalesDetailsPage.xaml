<UserControl x:Class="POS_WPF.Pages.SalesDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <!-- Delete button (red ghost) -->
        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#EF4444"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="ToolTip"         Value="Delete sale"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Expand / collapse chevron button -->
        <Style x:Key="ChevronBtn" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="*"/>
            <!-- Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <DockPanel Grid.Row="0" Margin="0,20,20,16" LastChildFill="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                <Viewbox Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Fill="#FF8C42" Stretch="Uniform"
                          Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                </Viewbox>
                <TextBlock Text="Sales History"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#4A4A4A" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- ===== SEARCH ===== -->
        <Border Grid.Row="1"
                Background="White" CornerRadius="12"
                BorderBrush="#DDE1E8" BorderThickness="1"
                Padding="12,0" Margin="0,0,20,14" Height="48">
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <TextBox x:Name="txtSearch"
                         Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" FontSize="14"
                         Padding="32,0,10,0" Foreground="#2F3640"
                         TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder"
                           Text="Search by client name or sale ID…"
                           Foreground="#A4B0BE" VerticalAlignment="Center"
                           FontSize="14" Margin="36,0,0,0" IsHitTestVisible="False"/>
                <TextBlock Text="🔍" VerticalAlignment="Center"
                           HorizontalAlignment="Left" Margin="10,0,0,0" FontSize="14"/>
            </Grid>
        </Border>

        <!-- ===== SALE CARDS ===== -->
        <ScrollViewer Grid.Row="2" x:Name="SaleScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,20,0">
            <StackPanel x:Name="SaleCardsContainer" Margin="0,0,0,10"/>
        </ScrollViewer>

        <!-- No data message -->
        <TextBlock x:Name="NoSalesMessage"
                   Grid.Row="2"
                   Text="No sales found"
                   Foreground="#9CA3AF" FontSize="16" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="3"
                Background="White" CornerRadius="8"
                Padding="12" Margin="0,6,20,16"
                HorizontalAlignment="Left">
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <TextBlock x:Name="txtTotalSales"
                       Text="Total Sales : 0"
                       FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50"/>
        </Border>

    </Grid>
</UserControl>