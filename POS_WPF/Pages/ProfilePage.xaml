<UserControl x:Class="POS_WPF.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:POS_WPF.Controls"
             xmlns:local="clr-namespace:POS_WPF.Pages"
             mc:Ignorable="d"
             Background="#F4F6FA">

    <UserControl.Resources>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                      Opacity="0.07" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Field value -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D23"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Divider -->
        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#F0F2F7"/>
            <Setter Property="Margin" Value="0,16"/>
        </Style>

        <!-- Orange action button -->
        <Style x:Key="OrangeBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10"
                                Padding="20,11">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF8C42" Offset="0"/>
                                    <GradientStop Color="#e06b1f" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF8C42" BlurRadius="14"
                                                  ShadowDepth="0" Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button (outline) -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF8C42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10"
                                Background="Transparent"
                                BorderBrush="#FF8C42"
                                BorderThickness="1.5"
                                Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFF3EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFE0C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10"
                                Background="#F05454"
                                Padding="20,11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════
                     ROW 0 — Hero / Avatar Card
                 ══════════════════════════════════════════ -->
            <Border Grid.Row="0" CornerRadius="16" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                      Opacity="0.07" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <!-- Banner gradient -->
                    <Border Height="110" VerticalAlignment="Top" CornerRadius="16,16,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF8C42" Offset="0"/>
                                <GradientStop Color="#e06b1f" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <!-- decorative circles on banner -->
                        <Canvas ClipToBounds="True">
                            <Ellipse Width="180" Height="180"
                                     Canvas.Right="-30" Canvas.Top="-60"
                                     Opacity="0.15" Fill="White"/>
                            <Ellipse Width="100" Height="100"
                                     Canvas.Right="120" Canvas.Top="-20"
                                     Opacity="0.10" Fill="White"/>
                        </Canvas>
                    </Border>

                    <!-- White body below banner -->
                    <Border Background="White" Margin="0,110,0,0"
                            CornerRadius="0,0,16,16" Padding="28,60,28,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name + meta -->
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="TxtFullName"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#1A1D23" FontFamily="Segoe UI"
                                           Margin="0,0,0,4"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="#FFF3EA" CornerRadius="6"
                                            Padding="10,4" Margin="0,0,8,0">
                                        <TextBlock Text="Administrator"
                                                   FontSize="11.5" FontWeight="SemiBold"
                                                   Foreground="#FF8C42" FontFamily="Segoe UI"/>
                                    </Border>
                                    <Border Background="#F0FFF4" CornerRadius="6"
                                            Padding="10,4">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Fill="#2DBD74"
                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="Active"
                                                       FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#2DBD74" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="@" FontSize="13"
                                               Foreground="#9099A8" FontFamily="Segoe UI"
                                               Margin="0,0,2,0"/>
                                    <TextBlock x:Name="TxtUsername"
                                               FontSize="13" Foreground="#9099A8"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button x:Name="BtnChangePassword"
                                        Style="{StaticResource GhostBtn}"
                                        Margin="0,0,10,0"
                                        Click="BtnChangePassword_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔑" FontSize="13"
                                                   Margin="0,0,7,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Change Password"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BtnLogout"
                                        Style="{StaticResource DangerBtn}"
                                        Click="BtnLogout_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏻" FontSize="14"
                                                   Margin="0,0,7,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Logout"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Avatar circle (overlaps banner / body) -->
                    <Border Width="90" Height="90"
                            CornerRadius="45"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="28,66,0,0"
                            BorderBrush="White"
                            BorderThickness="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                              Opacity="0.15" Color="#000000"/>
                        </Border.Effect>
                        <Border CornerRadius="45" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF8C42" Offset="0"/>
                                    <GradientStop Color="#e06b1f" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock x:Name="TxtInitials"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="White" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Border>

                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                     ROW 2 — Two column: Personal + Account
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Personal Information Card ── -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Card header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="#FFF3EA" Margin="0,0,12,0">
                                <TextBlock Text="👤" FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Personal Information"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1A1D23" FontFamily="Segoe UI"/>
                                <TextBlock Text="Your personal details"
                                           FontSize="11.5" Foreground="#9099A8"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- First Name -->
                        <TextBlock Text="FIRST NAME" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputFirstName"
                                              Placeholder="First name"
                                              IsRequired="True"
                                              ValidationType="AlphaNumeric"
                                              BorderRadius="10"
                                              MinLength="2"
                                              Margin="0,0,0,14"/>

                        <!-- Last Name -->
                        <TextBlock Text="LAST NAME" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputLastName"
                                              Placeholder="Last name"
                                              IsRequired="True"
                                              ValidationType="AlphaNumeric"
                                              BorderRadius="10"
                                              MinLength="2"
                                              Margin="0,0,0,14"/>

                        <!-- Phone -->
                        <TextBlock Text="PHONE" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputPhone"
                                              Placeholder="Phone number"
                                              BorderRadius="10"
                                              Margin="0,0,0,14"/>

                        <!-- Email -->
                        <TextBlock Text="EMAIL" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputEmail"
                                              Placeholder="Email address"
                                              BorderRadius="10"
                                              Margin="0,0,0,14"/>

                        <!-- Address -->
                        <TextBlock Text="ADDRESS" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputAddress"
                                              Placeholder="Address"
                                              BorderRadius="10"
                                              Margin="0,0,0,14"/>

                        <!-- Date of Birth -->
                        <TextBlock Text="DATE OF BIRTH" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputDob"
                                              Placeholder="YYYY-MM-DD"
                                              BorderRadius="10"
                                              Margin="0,0,0,20"/>

                        <!-- Gender -->
                        <TextBlock Text="GENDER" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CmbGender"
                                  Height="42"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  Foreground="#1A1D23"
                                  Margin="0,0,0,0">
                            <ComboBoxItem Content="Male"   Tag="0"/>
                            <ComboBoxItem Content="Female" Tag="1"/>
                        </ComboBox>

                    </StackPanel>
                </Border>

                <!-- ── Account Information Card ── -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Card header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="#FFF3EA" Margin="0,0,12,0">
                                <TextBlock Text="🔐" FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Account Information"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1A1D23" FontFamily="Segoe UI"/>
                                <TextBlock Text="Your login credentials"
                                           FontSize="11.5" Foreground="#9099A8"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Username field -->
                        <TextBlock Text="USERNAME" Style="{StaticResource SectionLabel}"/>
                        <controls:ModernInput x:Name="InputUsername"
                                              Placeholder="Username"
                                              IsRequired="True"
                                              ValidationType="AlphaNumeric"
                                              BorderRadius="10"
                                              MinLength="2"
                                              Margin="0,0,0,20"/>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- Read-only info section -->
                        <TextBlock Text="ACCOUNT DETAILS"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,16"/>

                        <!-- Person ID pill -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Person ID"
                                       FontSize="12.5" Foreground="#9099A8"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Background="#F4F6FA" CornerRadius="8"
                                    Padding="12,5">
                                <TextBlock x:Name="TxtPersonID"
                                           FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="#1A1D23" FontFamily="Segoe UI"/>
                            </Border>
                        </Grid>

                        <!-- Role row -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Role"
                                       FontSize="12.5" Foreground="#9099A8"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Background="#FFF3EA" CornerRadius="8"
                                    Padding="12,5">
                                <TextBlock Text="Administrator"
                                           FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="#FF8C42" FontFamily="Segoe UI"/>
                            </Border>
                        </Grid>

                        <!-- Status row -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Status"
                                       FontSize="12.5" Foreground="#9099A8"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Background="#F0FFF4" CornerRadius="8"
                                    Padding="12,5">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="#2DBD74"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0"/>
                                    <TextBlock Text="Active"
                                               FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="#2DBD74" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- Password hint -->
                        <Border CornerRadius="10" Background="#FFF3EA"
                                Padding="14,12" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <TextBlock Grid.Column="0"
                                           Text="🔑" FontSize="16"
                                           VerticalAlignment="Top"
                                           Margin="0,0,12,0"/>

                                <!-- Text content -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Want to change your password?"
                                               FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="#1A1D23" FontFamily="Segoe UI"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="Click the &quot;Change Password&quot; button at the top of the page to update your credentials securely."
                                               FontSize="11.5" Foreground="#9099A8"
                                               FontFamily="Segoe UI"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════
                     ROW 4 — Save / Danger Zone
                 ══════════════════════════════════════════ -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left — danger zone -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="⚠️" FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Danger Zone"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#F05454" FontFamily="Segoe UI"/>
                            <TextBlock Text="Logging out will end your current session."
                                       FontSize="11.5" Foreground="#9099A8"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                        <Button x:Name="BtnLogout2"
                                Style="{StaticResource DangerBtn}"
                                Margin="20,0,0,0"
                                Click="BtnLogout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏻" FontSize="14"
                                           Margin="0,0,7,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Logout" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Right — save button -->
                    <Button Grid.Column="1"
                            x:Name="BtnSave"
                            Style="{StaticResource OrangeBtn}"
                            Click="BtnSave_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Save Changes"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>