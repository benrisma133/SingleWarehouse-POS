<UserControl x:Class="POS_WPF.Pages.CategoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loadingIndicators="clr-namespace:LoadingIndicators.WPF;assembly=LoadingIndicators.WPF"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">


    <Grid Margin="20 ,0 ,0 ,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title + Add Button -->
            <RowDefinition Height="35.95"/>
            <!-- Search -->
            <RowDefinition Height="33.05"/>
            <!-- Cards -->
            <RowDefinition Height="*"/>
            <!-- Total Products -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <DockPanel Grid.Row="0"
                   Margin="0,20,20,20"
                   LastChildFill="False">

            <!-- LEFT : ICON + TITLE -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left">

                <!-- CATEGORY ICON -->
                <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                    <Canvas Width="48" Height="48">
                        <Rectangle Canvas.Left="6"
                                   Canvas.Top="28"
                                   Width="36"
                                   Height="14"
                                   RadiusX="4"
                                   RadiusY="4"
                                   Stroke="#FF8C42"
                                   StrokeThickness="4"/>

                        <Path Data="M20 7 H10 C7.8 7 6 8.8 6 11 V17 C6 19.2 7.8 21 10 21 H20"
                              Stroke="#FF8C42"
                              StrokeThickness="4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"/>

                        <Ellipse Canvas.Left="26"
                                 Canvas.Top="6"
                                 Width="16"
                                 Height="16"
                                 Fill="#2F88FF"
                                 Stroke="#FF8C42"
                                 StrokeThickness="4"/>

                        <Ellipse Canvas.Left="31"
                                 Canvas.Top="11"
                                 Width="6"
                                 Height="6"
                                 Fill="#FF8C42"/>
                    </Canvas>
                </Viewbox>

                <!-- TITLE -->
                <TextBlock Text="Category Management"
                           FontSize="26"
                           x:Name="txtTitle"
                           FontWeight="Bold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- RIGHT : GLOBAL BUTTON -->
            <Button Style="{StaticResource IconActionBtn}"
                    Width="160"
                    DockPanel.Dock="Right"
                    Click="BtnAddCategory_Click">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PLUS ICON -->
                    <Viewbox Width="18"
                             Height="18"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M12 5 L12 19 M5 12 L19 12"/>
                        </Canvas>
                    </Viewbox>

                    <!-- TEXT -->
                    <TextBlock Grid.Column="1"
                               Text="Add Category"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Button>

        </DockPanel>

        <!-- ================= SEARCH + FILTER ================= -->
        <Grid Grid.Row="1" VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Search -->
                <ColumnDefinition Width="*"/>
                <!-- spacing -->
                <!-- spacing -->
                <ColumnDefinition Width="240"/>
                <!-- ComboBox -->
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Grid Grid.Column="0" Height="65">
                <Border CornerRadius="12" Background="White" BorderBrush="#CED6E0" BorderThickness="1"/>
                <TextBox x:Name="txtSearch"
                     Background="Transparent"
                     BorderThickness="0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     Padding="35,0,5,0"
                     Foreground="#2F3640"
                     TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder"
                       Text=" Search product..."
                       Foreground="#A4B0BE"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Margin="35,0,5,0"
                       IsHitTestVisible="False"/>
                <TextBlock Text="🔍"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="10,0,0,0"
                       FontSize="16"
                       Foreground="#57606f"/>
            </Grid>

            <!-- STATUS FILTER COMBOBOX -->
            <ComboBox x:Name="cmbStatus"
                      Grid.Column="2"
                      Style="{StaticResource ModernComboBox}"
                      ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                      HorizontalAlignment="Right"
                      Width="220"
                      Height="45"
                      Margin="0,0,10,0"
                      VerticalAlignment="Center"
                      Cursor="Hand"
                      SelectionChanged="cmbStatus_SelectionChanged">
                <ComboBoxItem Content="All" Tag="all"/>
                <ComboBoxItem Content="Active" Tag="active"/>
                <ComboBoxItem Content="Not Active" Tag="inactive"/>
            </ComboBox>


        </Grid>

        <!-- ================= CARDS ================= -->
        <Grid Grid.Row="3">
            <ScrollViewer x:Name="CardScrollViewer"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              PanningMode="VerticalOnly"
              ClipToBounds="True">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track"
                       IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb x:Name="Thumb">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Rectangle Fill="#9CA3AF" RadiusX="3" RadiusY="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="False">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <Grid>
                    <!-- Cards container -->
                    <ItemsControl x:Name="DynamicCardContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="WrapPanelContainer" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <!-- No products message -->
                    <TextBlock x:Name="NoCategoriesMessage"
                Foreground="Gray"
                FontSize="18"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <Grid x:Name="LoadingOverlay"
                  Background="#F5F5F5"
                  Visibility="Collapsed">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Circular Spinner with small gap -->
                    <Grid Width="80" Height="80">
                        <!-- Background circle -->
                        <Ellipse Width="60" Height="60" 
                                 Stroke="#E0E0E0" 
                                 StrokeThickness="6"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>

                        <!-- Rotating Arc using Path -->
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="100" Height="100">
                                <Path Stroke="#4A4A4A" 
                                      StrokeThickness="10"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="50,10">
                                                <ArcSegment Point="10,50" 
                                                              Size="40,40" 
                                                              SweepDirection="Clockwise"
                                                              IsLargeArc="True"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" CenterX="50" CenterY="50" Angle="0"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" 
                                                         To="360"
                                                         Duration="0:0:0.8"
                                                         RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <TextBlock Text="Loading categories..." 
                   Foreground="#4A4A4A" 
                   FontWeight="SemiBold" 
                   FontSize="14" 
                   Margin="0,20,0,0" 
                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>



        <!-- ================= TOTAL PRODUCTS ================= -->
        <Border Grid.Row="4"
            Background="White"
            CornerRadius="8"
            Padding="12"
                Margin="0,10,10,10"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Effect="{StaticResource DropShadow}">
            <TextBlock x:Name="txtTotalProducts"
           Text="Total Categories : 0"
           FontSize="16"
           FontWeight="SemiBold"
           Foreground="#2C3E50"/>
        </Border>

    </Grid>
</UserControl>
