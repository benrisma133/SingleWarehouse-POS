<UserControl x:Class="POS_WPF.Pages.BrandPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POS_WPF.Pages"
             mc:Ignorable="d"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">

    <Grid Margin="20,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title + Add Button -->
            <RowDefinition Height="35.95"/>
            <!-- Search -->
            <RowDefinition Height="33.05"/>
            <!-- Cards -->
            <RowDefinition Height="*"/>
            <!-- Total -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER  ================= -->
        <DockPanel Grid.Row="0"
                   Margin="0,20,20,20"
                   LastChildFill="False">

            <!-- LEFT : ICON + TITLE -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left">

                <!-- BRAND ICON -->
                <Viewbox Width="20"
                        Height="20"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <Grid>
                        <!-- Tag shape -->
                        <Path
                           Fill="#FF8C42"
                           Stretch="Uniform"
                           Data="M1 5C1 2.79086 2.79086 1 5 1H9.75736C10.8182 1 11.8356 1.42143 12.5858 2.17157L21.5858 11.1716C23.1479 12.7337 23.1479 15.2663 21.5858 16.8284L16.8284 21.5858C15.2663 23.1479 12.7337 23.1479 11.1716 21.5858L2.17157 12.5858C1.42143 11.8356 1 10.8182 1 9.75736V5ZM5 3C3.89543 3 3 3.89543 3 5V9.75736C3 10.2878 3.21071 10.7965 3.58579 11.1716L12.5858 20.1716C13.3668 20.9526 14.6332 20.9526 15.4142 20.1716L20.1716 15.4142C20.9526 14.6332 20.9526 13.3668 20.1716 12.5858L11.1716 3.58579C10.7965 3.21071 10.2878 3 9.75736 3H5Z"/>

                        <!-- Hole -->
                        <Path
                           Fill="#FF8C42"
                           Data="M9 7.5C9 8.32843 8.32843 9 7.5 9C6.67157 9 6 8.32843 6 7.5C6 6.67157 6.67157 6 7.5 6C8.32843 6 9 6.67157 9 7.5Z"/>
                    </Grid>
                </Viewbox>


                <!-- TITLE -->
                <TextBlock Text="Brand Management"
                           FontSize="26"
                           x:Name="txtTitle"
                           FontWeight="Bold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- RIGHT : ADD BUTTON -->
            <Button Style="{StaticResource IconActionBtn}"
                    Width="160"
                    DockPanel.Dock="Right"
                    Click="BtnAddBrand_Click">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PLUS ICON -->
                    <Viewbox Width="18"
                             Height="18"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M12 5 L12 19 M5 12 L19 12"/>
                        </Canvas>
                    </Viewbox>

                    <!-- TEXT -->
                    <TextBlock Grid.Column="1"
                               Text="Add Brand"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Button>

        </DockPanel>

        <!-- ================= SEARCH + FILTER ================= -->
        <Grid Grid.Row="1" VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Search -->
                <ColumnDefinition Width="*"/>
                <!-- Spacing -->
                <ColumnDefinition Width="240"/>
                <!-- Status ComboBox -->
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Grid Grid.Column="0" Height="65">
                <Border CornerRadius="12" Background="White" BorderBrush="#CED6E0" BorderThickness="1"/>
                <TextBox x:Name="txtSearch"
                 Background="Transparent"
                 BorderThickness="0"
                 VerticalContentAlignment="Center"
                 FontSize="14"
                 Padding="35,0,5,0"
                 Foreground="#2F3640"
                 TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder"
                   Text=" Search brand..."
                   Foreground="#A4B0BE"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="35,0,5,0"
                   IsHitTestVisible="False"/>
                <TextBlock Text="🔍"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="10,0,0,0"
                   FontSize="16"
                   Foreground="#57606f"/>
            </Grid>

            <!-- STATUS FILTER COMBOBOX -->
            <ComboBox x:Name="cmbStatus"
                      Grid.Column="2"
                      Style="{StaticResource ModernComboBox}"
                      ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                      HorizontalAlignment="Right"
                      Width="220"
                      Height="45"
                      Margin="0,0,10,0"
                      VerticalAlignment="Center"
                      Cursor="Hand"
                      SelectionChanged="cmbStatus_SelectionChanged">
                <ComboBoxItem Content="All Brands" Tag="all"/>
                <ComboBoxItem Content="Active" Tag="active"/>
                <ComboBoxItem Content="Not Active" Tag="inactive"/>
            </ComboBox>

        </Grid>

        <!-- ================= CARDS ================= -->
        <Grid Grid.Row="3">
            <ScrollViewer x:Name="CardScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          ClipToBounds="True">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb x:Name="Thumb">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Rectangle Fill="#9CA3AF" RadiusX="3" RadiusY="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="False">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <Grid>
                    <!-- Cards container -->
                    <ItemsControl x:Name="DynamicCardContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="WrapPanelContainer" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <!-- No brands message -->
                    <TextBlock x:Name="NoBrandsMessage"
                               Foreground="Gray"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- LOADING OVERLAY -->
            <Grid x:Name="LoadingOverlay"
                  Background="#F5F5F5"
                  Visibility="Collapsed">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Grid Width="80" Height="80">
                        <Ellipse Width="60" Height="60"
                                 Stroke="#E0E0E0"
                                 StrokeThickness="6"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>

                        <Viewbox Width="60" Height="60">
                            <Canvas Width="100" Height="100">
                                <Path Stroke="#4A4A4A"
                                      StrokeThickness="10"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="50,10">
                                                <ArcSegment Point="10,50"
                                                            Size="40,40"
                                                            SweepDirection="Clockwise"
                                                            IsLargeArc="True"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" CenterX="50" CenterY="50" Angle="0"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:0.8"
                                                                     RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <TextBlock Text="Loading brands..."
                               Foreground="#4A4A4A"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,20,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ================= TOTAL BRANDS ================= -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="8"
                Padding="12"
                Margin="0,10,10,10"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Effect="{StaticResource DropShadow}">
            <TextBlock x:Name="txtTotalBrands"
                       Text="Total Brands : 0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"/>
        </Border>

    </Grid>
</UserControl>
