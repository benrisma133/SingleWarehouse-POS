                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#2DBD74"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold" Text="Modify "/>
                                        <Run Text="the brand name in the dialog that appears."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="6" Height="6" Fill="#2DBD74"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold" Text="Press Save "/>
                                        <Run Text="to apply changes. All series, models, and products under this brand will remain connected."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Border CornerRadius="8" Background="#EDFAF4"
                                        Padding="12,8" Margin="0,0,0,14">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="ℹ️" FontSize="13"
                                                   VerticalAlignment="Top" Margin="0,0,8,0"/>
                                                        <TextBlock FontSize="11.5" Foreground="#2DBD74"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Text="Note: "/>
                                            <Run Text="Renaming a brand only changes its display name. No series, models, or products are affected."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ── 3. DELETE BRAND ── -->
                                <Border CornerRadius="10" Background="#FFF8F8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <Border CornerRadius="10" Cursor="Hand"
                                MouseLeftButtonUp="DeleteBrand_Toggle">
                                            <Grid Margin="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="26" Height="26"
                                        CornerRadius="13" Background="#F05454"
                                        Margin="0,0,12,0">
                                                    <TextBlock Text="3" FontSize="11" FontWeight="Bold"
                                               Foreground="White" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Delete Brand"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1A1D23" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="▾"
                                           FontSize="12" Foreground="#9099A8"
                                           VerticalAlignment="Center">
                                                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="DeleteBrandArrowRotate" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="DeleteBrandContent"
                                Height="0" ClipToBounds="True">
                                            <StackPanel x:Name="DeleteBrandInner"
                                        Margin="14,0,14,0" Opacity="0">

                                                <Border Style="{StaticResource Divider}" Margin="0,0,0,10"/>

                                                <TextBlock Text="How to delete a brand:"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#F05454" FontFamily="Segoe UI"
                                           Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#F05454"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold" Text="Find "/>
                                        <Run Text="the brand you want to remove in the list."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#F05454"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold" Text="Click "/>
                                        <Run Text="the "/>
                                        <Run FontWeight="Bold" Foreground="#F05454" Text="Delete 🗑️ "/>
                                        <Run Text="icon next to the brand."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="6" Height="6" Fill="#F05454"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold" Text="The system will check "/>
                                        <Run Text="if this brand has any linked series, models, or products before proceeding."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Four Scenarios -->
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- No relations -->
                                                    <Border Grid.Row="0" Grid.Column="0"
                                            CornerRadius="8" Background="#EDFAF4" Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="✅  No relations"
                                                       FontSize="11.5" FontWeight="Bold"
                                                       Foreground="#2DBD74" FontFamily="Segoe UI"
                                                       Margin="0,0,0,5"/>
                                                            <TextBlock FontSize="11" Foreground="#4A5060"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Text="The brand is deleted immediately with a simple confirmation prompt."/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Has series only -->
                                                    <Border Grid.Row="0" Grid.Column="2"
                                            CornerRadius="8" Background="#FFF8E8" Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="⚠️  Has linked series"
                                                       FontSize="11.5" FontWeight="Bold"
                                                       Foreground="#E08C00" FontFamily="Segoe UI"
                                                       Margin="0,0,0,5"/>
                                                            <TextBlock FontSize="11" Foreground="#4A5060"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Text="A warning appears. Deleting the brand will also remove all series under it."/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Has series + models + products (full width) -->
                                                    <Border Grid.Row="2" Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            CornerRadius="8" Background="#FFF0F0" Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="🔴  Has series, models AND products"
                                                       FontSize="11.5" FontWeight="Bold"
                                                       Foreground="#F05454" FontFamily="Segoe UI"
                                                       Margin="0,0,0,5"/>
                                                            <TextBlock FontSize="11" Foreground="#4A5060"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Text="The most critical case. A strong warning appears. Deleting the brand will permanently remove the brand, all its series, all models under those series, and all products under those models."/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <!-- Warning Preview -->
                                                <Border CornerRadius="8" Margin="0,12,0,0"
                                        Background="#FFF0F0" BorderBrush="#F05454"
                                        BorderThickness="1.2" Padding="12,10">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="⚠️" FontSize="14"
                                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Warning Message Preview"
                                                       FontSize="11.5" FontWeight="Bold"
                                                       Foreground="#F05454" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Height="1" Background="#FFCDD2" Margin="0,0,0,8"/>
                                                        <TextBlock FontSize="11.5" Foreground="#5C3333"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"
                                                   FontStyle="Italic"
                                                   Text="&quot;This brand has linked series, models, and products. Deleting it will permanently remove the brand, all its series, all models under those series, and all products under those models. This action cannot be undone. Are you sure you want to continue?&quot;"/>
                                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,10,0,0">
                                                            <Border CornerRadius="5" Background="#E0E0E0"
                                                    Padding="10,4" Margin="0,0,6,0">
                                                                <TextBlock Text="Cancel" FontSize="11"
                                                           Foreground="#555555"
                                                           FontFamily="Segoe UI"
                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border CornerRadius="5" Background="#F05454"
                                                    Padding="10,4">
                                                                <TextBlock Text="Delete Anyway" FontSize="11"
                                                           Foreground="White"
                                                           FontFamily="Segoe UI"
                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Cascade diagram -->
                                                <Border CornerRadius="8" Background="#FFF5F9"
                                        Padding="12,10" Margin="0,10,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="🔗  What gets deleted (cascade)"
                                                   FontSize="11.5" FontWeight="Bold"
                                                   Foreground="#E91E8C" FontFamily="Segoe UI"
                                                   Margin="0,0,0,10"/>

                                                        <!-- Brand -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="#E91E8C"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#E91E8C"
                                                       FontFamily="Segoe UI"
                                                       Text="Brand (deleted)"/>
                                                        </StackPanel>

                                                        <!-- Series -->
                                                        <StackPanel Orientation="Horizontal" Margin="16,0,0,6">
                                                            <TextBlock Text="└─" FontSize="11"
                                                       Foreground="#9099A8"
                                                       FontFamily="Consolas"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="#7C4DFF"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#7C4DFF"
                                                       FontFamily="Segoe UI"
                                                       Text="All Series under this brand (deleted)"/>
                                                        </StackPanel>

                                                        <!-- Models -->
                                                        <StackPanel Orientation="Horizontal" Margin="32,0,0,6">
                                                            <TextBlock Text="└─" FontSize="11"
                                                       Foreground="#9099A8"
                                                       FontFamily="Consolas"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="#FF8C42"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#FF8C42"
                                                       FontFamily="Segoe UI"
                                                       Text="All Models under those series (deleted)"/>
                                                        </StackPanel>

                                                        <!-- Products -->
                                                        <StackPanel Orientation="Horizontal" Margin="48,0,0,0">
                                                            <TextBlock Text="└─" FontSize="11"
                                                       Foreground="#9099A8"
                                                       FontFamily="Consolas"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="#F05454"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#F05454"
                                                       FontFamily="Segoe UI"
                                                       Text="All Products under those models (deleted)"/>
                                                        </StackPanel>

                                                    </StackPanel>
                                                </Border>

                                                <!-- Final Warning -->
                                                <Border CornerRadius="8" Background="#FFF8E1"
                                        Padding="12,8" Margin="0,10,0,14">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔴" FontSize="13"
                                                   VerticalAlignment="Top" Margin="0,0,8,0"/>
                                                        <TextBlock FontSize="11.5" Foreground="#B8860B"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Text="Important: "/>
                                            <Run Text="Deleting a brand is the most destructive action in the entire system. It will permanently remove the brand, every series under it, every model under those series, and every product under those models. This cannot be undone under any circumstances."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>