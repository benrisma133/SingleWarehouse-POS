                                                    Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#7B1FA2" FontFamily="Segoe UI"
                                                       Text="Sale record (deleted)"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                                            <TextBlock Text="└─" FontSize="11" Foreground="#9099A8"
                                                       FontFamily="Consolas" Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="#F05454" VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="#F05454" FontFamily="Segoe UI"
                                                       Text="All Sale Detail lines for this sale (deleted)"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Warning Preview -->
                                                <Border CornerRadius="8" Margin="0,0,0,0"
                                        Background="#FFF0F0" BorderBrush="#F05454"
                                        BorderThickness="1.2" Padding="12,10">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="⚠️" FontSize="14"
                                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Warning Message Preview"
                                                       FontSize="11.5" FontWeight="Bold"
                                                       Foreground="#F05454" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Height="1" Background="#FFCDD2" Margin="0,0,0,8"/>
                                                        <TextBlock FontSize="11.5" Foreground="#5C3333"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"
                                                   FontStyle="Italic"
                                                   Text="&quot;Are you sure you want to delete this sale? This will permanently remove the sale and all its detail records. This action cannot be undone.&quot;"/>
                                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,10,0,0">
                                                            <Border CornerRadius="5" Background="#E0E0E0"
                                                    Padding="10,4" Margin="0,0,6,0">
                                                                <TextBlock Text="Cancel" FontSize="11"
                                                           Foreground="#555555"
                                                           FontFamily="Segoe UI"
                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border CornerRadius="5" Background="#F05454"
                                                    Padding="10,4">
                                                                <TextBlock Text="Delete Anyway" FontSize="11"
                                                           Foreground="White"
                                                           FontFamily="Segoe UI"
                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border CornerRadius="8" Background="#FFF8E1"
                                        Padding="12,8" Margin="0,10,0,14">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔴" FontSize="13"
                                                   VerticalAlignment="Top" Margin="0,0,8,0"/>
                                                        <TextBlock FontSize="11.5" Foreground="#B8860B"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Text="Important: "/>
                                            <Run Text="Deleting a sale does not restore the product quantities that were sold. Stock is not automatically reversed."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>