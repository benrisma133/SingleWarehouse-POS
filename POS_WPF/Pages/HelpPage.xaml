<UserControl x:Class="POS_WPF.Pages.HelpPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D23"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#F0F0F5"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── PAGE HEADER ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Help"
                           FontSize="26" FontWeight="Bold"
                           FontFamily="Segoe UI" Foreground="#1A1D23"/>
                <TextBlock Text="Quick guide to using the application"
                           FontSize="13" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ── HOW TO USE ── -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="How to Use" Style="{StaticResource SectionTitle}"/>

                    <!-- Item -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#FFF3EA" Margin="0,0,12,0">
                            <TextBlock Text="1" FontSize="12" FontWeight="Bold"
                                       Foreground="#FF8C42" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Add Products"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1A1D23" FontFamily="Segoe UI"/>
                            <TextBlock Text="Go to Products page and click Add to register a new product."
                                       FontSize="12" Foreground="#9099A8" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#FFF3EA" Margin="0,0,12,0">
                            <TextBlock Text="2" FontSize="12" FontWeight="Bold"
                                       Foreground="#FF8C42" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Make a Sale"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1A1D23" FontFamily="Segoe UI"/>
                            <TextBlock Text="Go to Sales page, select a client and add products to the cart."
                                       FontSize="12" Foreground="#9099A8" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#FFF3EA" Margin="0,0,12,0">
                            <TextBlock Text="3" FontSize="12" FontWeight="Bold"
                                       Foreground="#FF8C42" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Track Stock"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1A1D23" FontFamily="Segoe UI"/>
                            <TextBlock Text="Monitor low stock alerts on the Dashboard to restock on time."
                                       FontSize="12" Foreground="#9099A8" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}"/>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#FFF3EA" Margin="0,0,12,0">
                            <TextBlock Text="4" FontSize="12" FontWeight="Bold"
                                       Foreground="#FF8C42" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Transfer Stock"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1A1D23" FontFamily="Segoe UI"/>
                            <TextBlock Text="Use the Transfer option to move products between warehouses."
                                       FontSize="12" Foreground="#9099A8" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ── CONTACT SUPPORT ── -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Need More Help?" Style="{StaticResource SectionTitle}"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="#FFF3EA" Margin="0,0,12,0">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                                          Stroke="#FF8C42" StrokeThickness="1.5" Fill="Transparent" StrokeLineJoin="Round"/>
                                    <Path Data="M22 6l-10 7L2 6"
                                          Stroke="#FF8C42" StrokeThickness="1.5" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Contact the developer directly"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1A1D23" FontFamily="Segoe UI"/>
                            <TextBlock Text="ismail@email.com"
                                       FontSize="12" Foreground="#9099A8" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>