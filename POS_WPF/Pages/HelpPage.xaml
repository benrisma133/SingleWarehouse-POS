<UserControl x:Class="POS_WPF.Pages.HelpPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#F0F0F5"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PAGE HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Help"
                           FontSize="26" FontWeight="Bold"
                           FontFamily="Segoe UI" Foreground="#1A1D23"/>
                <TextBlock Text="Quick guide to using the application"
                           FontSize="13" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">

                <!-- ════════════════════════════════════
                         CATEGORIES TOPIC CARD
                     ════════════════════════════════════ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <!-- Topic Header (click to expand/collapse whole section) -->
                        <Border Cursor="Hand" CornerRadius="8"
                                MouseLeftButtonUp="CategoriesTopic_Toggle">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="38" Height="38"
                                        CornerRadius="8" Background="#EEF0FF"
                                        Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M3 7h18M3 12h18M3 17h18"
                                                  Stroke="#5B6BF8" StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Categories"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#1A1D23" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Manage your product categories"
                                               FontSize="12" Foreground="#9099A8"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="▾"
                                           FontSize="13" Foreground="#9099A8"
                                           VerticalAlignment="Center">
                                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="CategoriesTopicArrow" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Collapsible Body -->
                        <Border x:Name="CategoriesTopicContent"
                                Height="0" ClipToBounds="True">
                            <StackPanel x:Name="CategoriesTopicInner"
                                        Opacity="0" Margin="0,12,0,0">

                                <Border Style="{StaticResource Divider}" Margin="0,0,0,8"/>

                                <!-- ── 1. ADD CATEGORY ── -->
                                <Border CornerRadius="10" Background="#F8F9FF" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Border CornerRadius="10" Cursor="Hand"
                                                MouseLeftButtonUp="AddCategory_Toggle">
                                            <Grid Margin="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="26" Height="26"
                                                        CornerRadius="13" Background="#5B6BF8"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="1" FontSize="11" FontWeight="Bold"
                                                               Foreground="White" FontFamily="Segoe UI"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Add Category"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1A1D23" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="▾"
                                                           FontSize="12" Foreground="#9099A8"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="AddArrowRotate" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="AddCategoryContent"
                                                Height="0" ClipToBounds="True">
                                            <StackPanel x:Name="AddCategoryInner"
                                                        Margin="14,0,14,0" Opacity="0">

                                                <Border Style="{StaticResource Divider}" Margin="0,0,0,10"/>

                                                <TextBlock Text="How to add a new category:"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#5B6BF8" FontFamily="Segoe UI"
                                                           Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#5B6BF8"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Navigate "/>
                                                        <Run Text="to the Categories page from the left sidebar."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#5B6BF8"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Click "/>
                                                        <Run Text="the "/>
                                                        <Run FontWeight="Bold" Foreground="#5B6BF8" Text="&quot;Add Category&quot; "/>
                                                        <Run Text="button at the top right of the page."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#5B6BF8"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Enter "/>
                                                        <Run Text="a unique category name in the input field."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="6" Height="6" Fill="#5B6BF8"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Press Save "/>
                                                        <Run Text="to confirm. The new category will appear in the list immediately."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Border CornerRadius="8" Background="#EEF0FF"
                                                        Padding="12,8" Margin="0,0,0,14">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="💡" FontSize="13"
                                                                   VerticalAlignment="Top" Margin="0,0,8,0"/>
                                                        <TextBlock FontSize="11.5" Foreground="#5B6BF8"
                                                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="Tip: "/>
                                                            <Run Text="Category names must be unique. You cannot add two categories with the same name."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ── 2. UPDATE CATEGORY ── -->
                                <Border CornerRadius="10" Background="#F8FFF8" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Border CornerRadius="10" Cursor="Hand"
                                                MouseLeftButtonUp="UpdateCategory_Toggle">
                                            <Grid Margin="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="26" Height="26"
                                                        CornerRadius="13" Background="#2DBD74"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="2" FontSize="11" FontWeight="Bold"
                                                               Foreground="White" FontFamily="Segoe UI"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Update Category"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1A1D23" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="▾"
                                                           FontSize="12" Foreground="#9099A8"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="UpdateArrowRotate" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="UpdateCategoryContent"
                                                Height="0" ClipToBounds="True">
                                            <StackPanel x:Name="UpdateCategoryInner"
                                                        Margin="14,0,14,0" Opacity="0">

                                                <Border Style="{StaticResource Divider}" Margin="0,0,0,10"/>

                                                <TextBlock Text="How to update an existing category:"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#2DBD74" FontFamily="Segoe UI"
                                                           Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#2DBD74"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Go to "/>
                                                        <Run Text="the Categories page and find the category you want to edit."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#2DBD74"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Click "/>
                                                        <Run Text="the "/>
                                                        <Run FontWeight="Bold" Foreground="#2DBD74" Text="Edit ✏️ "/>
                                                        <Run Text="icon next to the category name."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#2DBD74"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Modify "/>
                                                        <Run Text="the category name in the dialog that appears."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="6" Height="6" Fill="#2DBD74"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="Press Save "/>
                                                        <Run Text="to apply changes. All products under this category will reflect the new name automatically."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Border CornerRadius="8" Background="#EDFAF4"
                                                        Padding="12,8" Margin="0,0,0,14">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="ℹ️" FontSize="13"
                                                                   VerticalAlignment="Top" Margin="0,0,8,0"/>
                                                        <TextBlock FontSize="11.5" Foreground="#2DBD74"
                                                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="Note: "/>
                                                            <Run Text="Updating a category name does not affect the products linked to it. They stay connected."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ── 3. DELETE CATEGORY ── -->
                                <Border CornerRadius="10" Background="#FFF8F8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <Border CornerRadius="10" Cursor="Hand"
                MouseLeftButtonUp="DeleteCategory_Toggle">
                                            <Grid Margin="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="26" Height="26"
                        CornerRadius="13" Background="#F05454"
                        Margin="0,0,12,0">
                                                    <TextBlock Text="3" FontSize="11" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Delete Category"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#1A1D23" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="▾"
                           FontSize="12" Foreground="#9099A8"
                           VerticalAlignment="Center">
                                                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="DeleteArrowRotate" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="DeleteCategoryContent"
                Height="0" ClipToBounds="True">
                                            <StackPanel x:Name="DeleteCategoryInner"
                        Margin="14,0,14,0" Opacity="0">

                                                <Border Style="{StaticResource Divider}" Margin="0,0,0,10"/>

                                                <TextBlock Text="How to delete a category:"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#F05454" FontFamily="Segoe UI"
                           Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#F05454"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                               FontFamily="Segoe UI" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Text="Find "/>
                        <Run Text="the category you want to remove in the list."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Ellipse Width="6" Height="6" Fill="#F05454"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                               FontFamily="Segoe UI" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Text="Click "/>
                        <Run Text="the "/>
                        <Run FontWeight="Bold" Foreground="#F05454" Text="Delete 🗑️ "/>
                        <Run Text="icon next to the category."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="6" Height="6" Fill="#F05454"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock FontSize="12" Foreground="#4A5060"
                               FontFamily="Segoe UI" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Text="The system will check "/>
                        <Run Text="if this category has linked products before proceeding."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Two Scenarios -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- No linked products -->
                                                    <Border Grid.Column="0" CornerRadius="8"
                            Background="#EDFAF4" Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="✅  No linked products"
                                       FontSize="11.5" FontWeight="Bold"
                                       Foreground="#2DBD74" FontFamily="Segoe UI"
                                       Margin="0,0,0,5"/>
                                                            <TextBlock FontSize="11" Foreground="#4A5060"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                       Text="The category is deleted immediately with a simple confirmation."/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Has linked products -->
                                                    <Border Grid.Column="2" CornerRadius="8"
                            Background="#FFF0F0" Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="⚠️  Has linked products"
                                       FontSize="11.5" FontWeight="Bold"
                                       Foreground="#F05454" FontFamily="Segoe UI"
                                       Margin="0,0,0,5"/>
                                                            <TextBlock FontSize="11" Foreground="#4A5060"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                       Text="The system shows a message with the total linked products count and asks if you want to delete anyway."/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <!-- Warning Preview -->
                                                <Border CornerRadius="8" Margin="0,10,0,0"
                        Background="#FFF0F0" BorderBrush="#F05454"
                        BorderThickness="1.2" Padding="12,10">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="⚠️" FontSize="14"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Warning Message Preview"
                                       FontSize="11.5" FontWeight="Bold"
                                       Foreground="#F05454" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Height="1" Background="#FFCDD2" Margin="0,0,0,8"/>
                                                        <TextBlock FontSize="11.5" Foreground="#5C3333"
                                   FontFamily="Segoe UI" TextWrapping="Wrap"
                                   FontStyle="Italic"
                                   Text="&quot;Cannot delete this category. It is linked with: - 3 Products. Do you want to delete anyway?&quot;"/>
                                                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,10,0,0">
                                                            <Border CornerRadius="5" Background="#E0E0E0"
                                    Padding="10,4" Margin="0,0,6,0">
                                                                <TextBlock Text="Cancel" FontSize="11"
                                           Foreground="#555555"
                                           FontFamily="Segoe UI"
                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border CornerRadius="5" Background="#F05454"
                                    Padding="10,4">
                                                                <TextBlock Text="Delete Anyway" FontSize="11"
                                           Foreground="White"
                                           FontFamily="Segoe UI"
                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Deactivate tip -->
                                                <Border CornerRadius="8" Background="#EEF0FF"
                        Padding="12,8" Margin="0,10,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                   Text="💡" FontSize="13"
                                   VerticalAlignment="Top"
                                   Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1"
                                   FontSize="11.5" Foreground="#5B6BF8"
                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold" Text="Tip: "/>
                            <Run Text="Instead of deleting, you can "/>
                            <Run FontWeight="Bold" Text="deactivate"/>
                            <Run Text=" the category. Deactivating hides it from the system without removing any data or breaking any existing links."/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>

                                                <!-- Final Warning -->
                                                <Border CornerRadius="8" Background="#FFF8E1"
                        Padding="12,8" Margin="0,10,0,14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                   Text="🔴" FontSize="13"
                                   VerticalAlignment="Top"
                                   Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1"
                                   FontSize="11.5" Foreground="#B8860B"
                                   FontFamily="Segoe UI" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold" Text="Important: "/>
                            <Run Text="Deleting a category that has linked products will permanently remove all those products as well. If you are not sure, use deactivate instead."/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════
                         MODELS TOPIC CARD
                     ════════════════════════════════════ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <!-- Topic Header -->
                        <Border Cursor="Hand" CornerRadius="8"
                                MouseLeftButtonUp="ModelsTopic_Toggle">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="38" Height="38"
                                        CornerRadius="8" Background="#FFF3EA"
                                        Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M12 2L2 7l10 5 10-5-10-5z"
                                                  Stroke="#FF8C42" StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  StrokeLineJoin="Round"/>
                                            <Path Data="M2 17l10 5 10-5"
                                                  Stroke="#FF8C42" StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                            <Path Data="M2 12l10 5 10-5"
                                                  Stroke="#FF8C42" StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Models"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#1A1D23" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Manage your product models"
                                               FontSize="12" Foreground="#9099A8"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="▾"
                                           FontSize="13" Foreground="#9099A8"
                                           VerticalAlignment="Center">
                                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="ModelsTopicArrow" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Collapsible Body -->
                        <Border x:Name="ModelsTopicContent"
                                Height="0" ClipToBounds="True">
                            <StackPanel x:Name="ModelsTopicInner"
                                        Opacity="0" Margin="0,12,0,0">

                                <Border Style="{StaticResource Divider}" Margin="0,0,0,8"/>

                                <!-- ── 1. ADD MODEL ── -->
                                <Border CornerRadius="10" Background="#FFF9F5" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Border CornerRadius="10" Cursor="Hand"
                                                MouseLeftButtonUp="AddModel_Toggle">
