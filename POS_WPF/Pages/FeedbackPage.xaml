<UserControl x:Class="POS_WPF.Pages.FeedbackPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D23"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#2D3142"/>
            <Setter Property="Background" Value="#F4F6FA"/>
            <Setter Property="BorderBrush" Value="#E0E4ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OrangeBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF8C42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E0E4ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── PAGE HEADER ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Feedback"
                           FontSize="26" FontWeight="Bold"
                           FontFamily="Segoe UI" Foreground="#1A1D23"/>
                <TextBlock Text="Share your thoughts or report a problem"
                           FontSize="13" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ── FORM CARD ── -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Send Feedback" Style="{StaticResource SectionTitle}"/>

                    <!-- Type -->
                    <TextBlock Text="TYPE" Style="{StaticResource InputLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="rbSuggestion" Content="Suggestion"
                                     IsChecked="True"
                                     Checked="FeedbackType_Checked"
                                     FontFamily="Segoe UI" FontSize="13"
                                     Foreground="#2D3142" Margin="0,0,20,0"/>
                        <RadioButton x:Name="rbBug" Content="Bug Report"
                                     Checked="FeedbackType_Checked"
                                     FontFamily="Segoe UI" FontSize="13"
                                     Foreground="#2D3142" Margin="0,0,20,0"/>
                        <RadioButton x:Name="rbOther" Content="Other"
                                     Checked="FeedbackType_Checked"
                                     FontFamily="Segoe UI" FontSize="13"
                                     Foreground="#2D3142"/>
                    </StackPanel>

                    <!-- Other type textbox (hidden by default) -->
                    <StackPanel x:Name="pnlOtherType"
                                Visibility="Collapsed"
                                Margin="0,0,0,16">
                        <TextBlock Text="SPECIFY TYPE" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtOtherType" Style="{StaticResource InputBox}"/>
                    </StackPanel>

                    <!-- Name (optional) -->
                    <TextBlock Text="YOUR NAME (OPTIONAL)" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="txtSenderName"
                             Style="{StaticResource InputBox}"
                             Margin="0,0,0,16"/>

                    <!-- Title -->
                    <TextBlock Text="TITLE" Style="{StaticResource InputLabel}" Margin="0,4,0,6"/>
                    <TextBox x:Name="txtTitle"
                             Style="{StaticResource InputBox}"
                             Margin="0,0,0,16"/>

                    <!-- Message -->
                    <TextBlock Text="MESSAGE" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="txtMessage"
                             Style="{StaticResource InputBox}"
                             Height="120"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,24"/>

                    <!-- Sending indicator -->
                    <StackPanel x:Name="pnlSending"
                                Orientation="Horizontal"
                                Visibility="Collapsed"
                                Margin="0,0,0,12">
                        <TextBlock Text="Sending..."
                                   FontSize="12" Foreground="#9099A8"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnClear" Content="Clear"
                                Style="{StaticResource GhostBtn}"
                                Click="btnClear_Click"
                                Margin="0,0,10,0"/>
                        <Button x:Name="btnSubmit" Content="Send to Developer"
                                Style="{StaticResource OrangeBtn}"
                                Click="btnSubmit_Click"/>
                    </StackPanel>

                    <!-- Success -->
                    <Border x:Name="pnlSuccess"
                            Background="#E8F5E9" CornerRadius="8"
                            Padding="14,10" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="✓  Feedback sent successfully. Thank you!"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#2E7D32" FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Error -->
                    <Border x:Name="pnlError"
                            Background="#FFEBEE" CornerRadius="8"
                            Padding="14,10" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="txtError"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#C62828" FontFamily="Segoe UI"
                                   TextWrapping="Wrap"/>
                    </Border>

                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>