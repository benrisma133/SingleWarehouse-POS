<UserControl x:Class="POS_WPF.Pages.AboutSystemPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D23"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2D3142"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#F0F0F5"/>
            <Setter Property="Margin" Value="0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── PAGE HEADER ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="About System"
                           FontSize="26" FontWeight="Bold"
                           FontFamily="Segoe UI" Foreground="#1A1D23"/>
                <TextBlock Text="Application version, environment and system details"
                           FontSize="13" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ── TOP ROW: App Identity + Version ── -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- App Identity -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- App Icon -->
                        <Border Width="64" Height="64" CornerRadius="16"
                                Background="#FFF3EA" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <Viewbox Width="32" Height="32">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Canvas.Left="2" Canvas.Top="3" Width="20" Height="14"
                                               RadiusX="2" RadiusY="2"
                                               Stroke="#FF8C42" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Path Data="M8 21H16M12 17V21"
                                          Stroke="#FF8C42" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <TextBlock Text="POS System"
                                   FontSize="22" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="#1A1D23"/>
                        <TextBlock Text="Point of Sale Desktop Application"
                                   FontSize="12" Foreground="#9099A8"
                                   FontFamily="Segoe UI" Margin="0,4,0,16"/>

                        <Border Background="#FFF3EA" CornerRadius="8"
                                Padding="12,6" HorizontalAlignment="Left">
                            <TextBlock Text="v1.0.0  —  Stable Release"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF8C42" FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Build Info -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Build Information" Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="VERSION" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.0" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Divider}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="BUILD DATE" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="April 2025" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <Border Grid.Row="3" Grid.ColumnSpan="2" Style="{StaticResource Divider}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ARCHITECTURE" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="x64" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <Border Grid.Row="5" Grid.ColumnSpan="2" Style="{StaticResource Divider}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="LICENSE" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Private / Personal Use" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── BOTTOM ROW: Environment Details ── -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Environment" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- OS -->
                        <Border Grid.Column="0" Background="#F4F6FA" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                            <StackPanel>
                                <Border Width="36" Height="36" CornerRadius="8" Background="White" Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                                                  Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="OPERATING SYSTEM" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                <TextBlock Text="Windows 10 / 11" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2D3142" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <!-- Runtime -->
                        <Border Grid.Column="1" Background="#F4F6FA" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                            <StackPanel>
                                <Border Width="36" Height="36" CornerRadius="8" Background="White" Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                                                  Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="RUNTIME" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                <TextBlock Text=".NET Framework 4.8" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2D3142" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <!-- Database -->
                        <Border Grid.Column="2" Background="#F4F6FA" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                            <StackPanel>
                                <Border Width="36" Height="36" CornerRadius="8" Background="White" Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="20" Height="6"
                                                     Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M2 8v4c0 1.657 4.477 3 10 3s10-1.343 10-3V8"
                                                  Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Path Data="M2 12v4c0 1.657 4.477 3 10 3s10-1.343 10-3v-4"
                                                  Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="DATABASE" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                <TextBlock Text="SQLite 3 (local)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2D3142" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <!-- UI Framework -->
                        <Border Grid.Column="3" Background="#F4F6FA" CornerRadius="10" Padding="16,14">
                            <StackPanel>
                                <Border Width="36" Height="36" CornerRadius="8" Background="White" Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Rectangle Canvas.Left="3" Canvas.Top="3" Width="18" Height="18"
                                                       RadiusX="2" RadiusY="2"
                                                       Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M3 9h18M9 21V9"
                                                  Stroke="#9099A8" StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="UI FRAMEWORK" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                <TextBlock Text="WPF / XAML" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2D3142" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>