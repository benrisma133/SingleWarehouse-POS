                                    <Rectangle Canvas.Left="164" Canvas.Top="195"
                                               Width="50" Height="1.5"
                                               RadiusX="0.75" RadiusY="0.75"
                                               Fill="#FF8C42" Opacity="0.3"/>

                                    <!-- Touchpad -->
