<UserControl x:Class="POS_WPF.Pages.SeriePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:POS_WPF.Pages"
             mc:Ignorable="d"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">

    <Grid Margin="20,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title + Add Button -->
            <RowDefinition Height="35.95"/>
            <!-- Search -->
            <RowDefinition Height="33.05"/>
            <!-- Cards -->
            <RowDefinition Height="*"/>
            <!-- Total -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <DockPanel Grid.Row="0"
                   Margin="0,20,20,20"
                   LastChildFill="False">

            <!-- LEFT : ICON + TITLE -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left">

                <!-- SERIE ICON -->
                <Viewbox Width="20"
                         Height="20"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center">
                    <Path Fill="#FF8C42"
                          Stretch="Uniform"
                          Data="M3.05 4.75a.7.7 0 01.7-.7h3.5a.7.7 0 110 1.4h-3.5a.7.7 0 01-.7-.7z
                                M3.75 7.05a.7.7 0 100 1.4h2.5a.7.7 0 100-1.4h-2.5z
                                M0 3.25A2.25 2.25 0 012.25 1h6.5c.883 0 1.648.51 2.016 1.25h.984
                                c.698 0 1.3.409 1.582 1h.918c.966 0 1.75.784 1.75 1.75v6
                                a1.75 1.75 0 01-1.75 1.75h-.918c-.281.591-.884 1-1.582 1
                                h-.984A2.25 2.25 0 018.75 15h-6.5A2.25 2.25 0 010 12.75v-9.5z
                                M13.5 11.25h.75a.25.25 0 00.25-.25V5a.25.25 0 00-.25-.25h-.75v6.5z
                                M11 12.25v-8.5h.75A.25.25 0 0112 4v8a.25.25 0 01-.25.25H11z
                                M2.25 2.5a.75.75 0 00-.75.75v9.5c0 .414.336.75.75.75h6.5
                                a.75.75 0 00.75-.75v-9.5a.75.75 0 00-.75-.75h-6.5z"/>
                </Viewbox>

                <!-- TITLE -->
                <TextBlock Text="Serie Management"
                           FontSize="26"
                           x:Name="txtTitle"
                           FontWeight="Bold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- RIGHT : ADD BUTTON -->
            <Button Style="{StaticResource IconActionBtn}"
                    Width="160"
                    DockPanel.Dock="Right"
                    Click="BtnAddSerie_Click">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PLUS ICON -->
                    <Viewbox Width="18"
                             Height="18"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M12 5 L12 19 M5 12 L19 12"/>
                        </Canvas>
                    </Viewbox>

                    <!-- TEXT -->
                    <TextBlock Grid.Column="1"
                               Text="Add Serie"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Button>

        </DockPanel>

        <!-- ================= SEARCH + FILTER ================= -->
        <Grid Grid.Row="1" VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Search -->
                <ColumnDefinition Width="*"/>
                <!-- Spacing -->
                <ColumnDefinition Width="240"/>
                <!-- Warehouse ComboBox -->
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Grid Grid.Column="0" Height="65">
                <Border CornerRadius="12" Background="White" BorderBrush="#CED6E0" BorderThickness="1"/>
                <TextBox x:Name="txtSearch"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Padding="35,0,5,0"
                         Foreground="#2F3640"
                         TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder"
                           Text=" Search serie..."
                           Foreground="#A4B0BE"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Margin="35,0,5,0"
                           IsHitTestVisible="False"/>
                <TextBlock Text="🔍"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           FontSize="16"
                           Foreground="#57606f"/>
            </Grid>

            <!-- STATUS FILTER COMBOBOX -->
            <ComboBox x:Name="cmbStatus"
                      Grid.Column="2"
                      Style="{StaticResource ModernComboBox}"
                      ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                      HorizontalAlignment="Right"
                      Width="220"
                      Height="45"
                      Margin="0,0,10,0"
                      VerticalAlignment="Center"
                      Cursor="Hand"
                      SelectionChanged="cmbStatus_SelectionChanged">
                <ComboBoxItem Content="All Brands" Tag="all"/>
                <ComboBoxItem Content="Active" Tag="active"/>
                <ComboBoxItem Content="Not Active" Tag="inactive"/>
            </ComboBox>

        </Grid>

        <!-- ================= CARDS ================= -->
        <Grid Grid.Row="3">
            <ScrollViewer x:Name="CardScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          ClipToBounds="True">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb x:Name="Thumb">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Rectangle Fill="#9CA3AF" RadiusX="3" RadiusY="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="False">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <Grid>
                    <!-- Cards container -->
                    <ItemsControl x:Name="DynamicCardContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="WrapPanelContainer" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <!-- No series message -->
                    <TextBlock x:Name="NoSeriesMessage"
                               Foreground="Gray"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- LOADING OVERLAY -->
            <Grid x:Name="LoadingOverlay"
                  Background="#F5F5F5"
                  Visibility="Collapsed">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Grid Width="80" Height="80">
                        <Ellipse Width="60" Height="60"
                                 Stroke="#E0E0E0"
                                 StrokeThickness="6"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>

                        <Viewbox Width="60" Height="60">
                            <Canvas Width="100" Height="100">
                                <Path Stroke="#4A4A4A"
                                      StrokeThickness="10"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="50,10">
                                                <ArcSegment Point="10,50"
                                                            Size="40,40"
                                                            SweepDirection="Clockwise"
                                                            IsLargeArc="True"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" CenterX="50" CenterY="50" Angle="0"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:0.8"
                                                                     RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <TextBlock Text="Loading series..."
                               Foreground="#4A4A4A"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,20,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ================= TOTAL SERIES ================= -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="8"
                Padding="12"
                Margin="0,10,10,10"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Effect="{StaticResource DropShadow}">
            <TextBlock x:Name="txtTotalSeries"
                       Text="Total Series : 0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"/>
        </Border>

    </Grid>
</UserControl>
