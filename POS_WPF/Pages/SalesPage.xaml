<UserControl x:Class="POS_WPF.Pages.SalesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:POS_WPF.Pages"
             mc:Ignorable="d"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <!-- Quantity button style -->
        <Style x:Key="QtyBtn" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DDE1E8"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#4A4A4A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F0F4FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF8C42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFE8D5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Remove button style -->
        <Style x:Key="RemoveBtn" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#EF4444"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Add-to-cart button -->
        <Style x:Key="AddToCartBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="#FF8C42"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Confirm sale button -->
        <Style x:Key="ConfirmBtn" TargetType="Button" BasedOn="{StaticResource AddToCartBtn}">
            <Setter Property="Background"  Value="#10B981"/>
            <Setter Property="Height"      Value="44"/>
            <Setter Property="FontSize"    Value="15"/>
        </Style>

        <!-- Cancel button -->
        <Style x:Key="CancelSaleBtn" TargetType="Button" BasedOn="{StaticResource AddToCartBtn}">
            <Setter Property="Background" Value="#5E5E5E"/>
            <Setter Property="Height"     Value="44"/>
            <Setter Property="FontSize"   Value="15"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Client selector -->
            <RowDefinition Height="*"/>
            <!-- Products | Cart -->
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <DockPanel Grid.Row="0" Margin="0,20,20,16" LastChildFill="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                <Viewbox Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Fill="#FF8C42" Stretch="Uniform"
                          Data="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96C5 16.1 5.9 17 7 17h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63H19c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0023.42 4H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
                </Viewbox>
                <TextBlock Text="New Sale"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- ========== CLIENT SELECTOR ========== -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                BorderBrush="#DDE1E8"
                BorderThickness="1"
                Padding="16,12"
                Margin="0,0,20,16">
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" BlurRadius="8"
                                  ShadowDepth="1" Opacity="0.10"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Client :"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <ComboBox x:Name="cmbClients"
                          Grid.Column="1"
                          Height="40"
                          FontSize="14"
                          Padding="10,0"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="ClientID"
                          SelectionChanged="cmbClients_SelectionChanged"/>

                <Button Grid.Column="2"
                        Style="{StaticResource AddToCartBtn}"
                        Margin="12,0,0,0"
                        Height="40"
                        Click="BtnNewClient_Click">
                    + New Client
                </Button>

                <!-- Selected client info pill -->
                <Border x:Name="ClientInfoPill"
                        Grid.Column="3"
                        Background="#FFF3E8"
                        CornerRadius="8"
                        Padding="12,6"
                        Margin="16,0,0,0"
                        Visibility="Collapsed"
                        HorizontalAlignment="Left">
                    <TextBlock x:Name="txtClientInfo"
                               FontSize="13"
                               Foreground="#92400E"/>
                </Border>
            </Grid>
        </Border>

        <!-- ========== MAIN AREA : Products | Cart ========== -->
        <Grid Grid.Row="2" Margin="0,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT : PRODUCTS ===== -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#DDE1E8"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#94A3B8" BlurRadius="8"
                                      ShadowDepth="1" Opacity="0.10"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- search bar -->
                        <RowDefinition Height="*"/>
                        <!-- product cards -->
                    </Grid.RowDefinitions>

                    <!-- Search -->
                    <Border Grid.Row="0"
                            BorderBrush="#EEF0F4"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <Grid>
                            <Border CornerRadius="10"
                                    Background="#F7F8FA"
                                    BorderBrush="#DDE1E8"
                                    BorderThickness="1"/>
                            <TextBox x:Name="txtProductSearch"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     Padding="34,0,10,0"
                                     Height="38"
                                     Foreground="#2F3640"
                                     TextChanged="txtProductSearch_TextChanged"/>
                            <TextBlock x:Name="txtProductPlaceholder"
                                       Text=" Search products..."
                                       Foreground="#A4B0BE"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Margin="34,0,0,0"
                                       IsHitTestVisible="False"/>
                            <TextBlock Text="🔍"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Margin="10,0,0,0"
                                       FontSize="14"/>
                        </Grid>
                    </Border>

                    <!-- Product cards scroll area -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="ProductScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,10,14,10">
                        <StackPanel x:Name="ProductListContainer"/>
                    </ScrollViewer>

                    <!-- No products overlay -->
                    <TextBlock x:Name="NoProductsMessage"
                               Grid.Row="1"
                               Text="No products available"
                               Foreground="#9CA3AF"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- ===== RIGHT : CART ===== -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#DDE1E8"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#94A3B8" BlurRadius="8"
                                      ShadowDepth="1" Opacity="0.10"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Cart header -->
                        <RowDefinition Height="*"/>
                        <!-- Cart items -->
                        <RowDefinition Height="Auto"/>
                        <!-- Total + actions -->
                    </Grid.RowDefinitions>

                    <!-- Cart header -->
                    <Border Grid.Row="0"
                            BorderBrush="#EEF0F4"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Text="🛒" FontSize="18" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Cart"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="CartCountBadge"
                                        Background="#FF8C42"
                                        CornerRadius="10"
                                        Padding="6,2"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="txtCartCount"
                                               Text="0"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource RemoveBtn}"
                                    Width="Auto"
                                    Height="28"
                                    Padding="8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#EF4444"
                                    Click="BtnClearCart_Click"
                                    ToolTip="Clear all items">
                                Clear all
                            </Button>
                        </DockPanel>
                    </Border>

                    <!-- Cart items list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12,8">
                        <StackPanel x:Name="CartItemsContainer"/>
                    </ScrollViewer>

                    <!-- Empty cart message -->
                    <TextBlock x:Name="EmptyCartMessage"
                               Grid.Row="1"
                               Text="Cart is empty&#x0a;Add products from the left"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Visible"/>

                    <!-- Total + Buttons -->
                    <Border Grid.Row="2"
                            BorderBrush="#EEF0F4"
                            BorderThickness="0,1,0,0"
                            Padding="16,14">
                        <StackPanel>

                            <!-- Total row -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtTotal"
                                           Grid.Column="1"
                                           Text="$0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#FF8C42"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Confirm -->
                            <Button Style="{StaticResource ConfirmBtn}"
                                    Click="BtnConfirmSale_Click"
                                    Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓" FontSize="16" Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Confirm Sale" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Cancel -->
                            <Button Style="{StaticResource CancelSaleBtn}"
                                    Click="BtnCancelSale_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>