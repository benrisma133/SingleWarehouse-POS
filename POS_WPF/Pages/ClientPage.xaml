<UserControl x:Class="POS_WPF.Pages.ClientPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:POS_WPF.Pages"
             mc:Ignorable="d"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">

    <Grid Margin="20,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="35.95"/>
            <RowDefinition Height="33.05"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <DockPanel Grid.Row="0"
                   Margin="0,20,20,20"
                   LastChildFill="False">

            <!-- LEFT : ICON + TITLE -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left">

                <Viewbox Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Fill="#FF8C42" Stretch="Uniform"
                          Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </Viewbox>

                <TextBlock x:Name="txtTitle"
                           Text="Client Management"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- RIGHT : ADD BUTTON -->
            <Button Style="{StaticResource IconActionBtn}"
                    Width="160"
                    DockPanel.Dock="Right"
                    Click="BtnAddClient_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M12 5 L12 19 M5 12 L19 12"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="Add Client"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Button>

        </DockPanel>

        <!-- ================= SEARCH + FILTER ================= -->
        <Grid Grid.Row="1" VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Search -->
                <ColumnDefinition Width="*"/>
                <!-- Spacing -->
                <ColumnDefinition Width="240"/>
                <!-- Warehouse ComboBox -->
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Grid Grid.Column="0" Height="65">
                <Border CornerRadius="12" Background="White" BorderBrush="#CED6E0" BorderThickness="1"/>
                <TextBox x:Name="txtSearch"
                 Background="Transparent"
                 BorderThickness="0"
                 VerticalContentAlignment="Center"
                 FontSize="14"
                 Padding="35,0,5,0"
                 Foreground="#2F3640"
                 TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder"
                   Text=" Search client..."
                   Foreground="#A4B0BE"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="35,0,5,0"
                   IsHitTestVisible="False"/>
                <TextBlock Text="🔍"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="10,0,0,0"
                   FontSize="16"
                   Foreground="#57606f"/>
            </Grid>

            <!-- STATUS FILTER COMBOBOX -->
            <ComboBox x:Name="cmbStatus"
              Grid.Column="2"
              Style="{StaticResource ModernComboBox}"
              ItemContainerStyle="{StaticResource ModernComboBoxItem}"
              HorizontalAlignment="Right"
              Width="220"
              Height="45"
              Margin="0,0,10,0"
              VerticalAlignment="Center"
              Cursor="Hand"
              SelectionChanged="cmbStatus_SelectionChanged">
                <ComboBoxItem Content="All" Tag="all"/>
                <ComboBoxItem Content="Active" Tag="active"/>
                <ComboBoxItem Content="Not Active" Tag="inactive"/>
            </ComboBox>

        </Grid>

        <!-- ================= CARDS ================= -->
        <Grid Grid.Row="3">
            <ScrollViewer x:Name="CardScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          ClipToBounds="True">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb x:Name="Thumb">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Rectangle Fill="#9CA3AF" RadiusX="3" RadiusY="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="False">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>

                <Grid>
                    <ItemsControl x:Name="DynamicCardContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="WrapPanelContainer" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock x:Name="NoClientsMessage"
                               Foreground="Gray"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- LOADING OVERLAY -->
            <Grid x:Name="LoadingOverlay"
                  Background="#F5F5F5"
                  Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="80" Height="80">
                        <Ellipse Width="60" Height="60"
                                 Stroke="#E0E0E0" StrokeThickness="6"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="100" Height="100">
                                <Path Stroke="#4A4A4A" StrokeThickness="10"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="50,10">
                                                <ArcSegment Point="10,50" Size="40,40"
                                                            SweepDirection="Clockwise"
                                                            IsLargeArc="True"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate"
                                                         CenterX="50" CenterY="50" Angle="0"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360"
                                                                     Duration="0:0:0.8"
                                                                     RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                    <TextBlock Text="Loading clients..."
                               Foreground="#4A4A4A"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,20,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ================= TOTAL CLIENTS ================= -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="8"
                Padding="12"
                Margin="0,10,10,10"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Effect="{StaticResource DropShadow}">
            <TextBlock x:Name="txtTotalClients"
                       Text="Total Clients : 0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"/>
        </Border>

    </Grid>
</UserControl>