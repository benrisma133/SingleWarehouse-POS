<UserControl x:Class="POS_WPF.Pages.ModelPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">

    <Grid Margin="20,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="35.95"/>
            <RowDefinition Height="33.05"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Grid.Row="0" Margin="0,20,20,20" LastChildFill="False">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                    <Path Fill="#FF8C42" Stretch="Uniform"
                          Data="M26 30H42a2 2 0 0 0 2-2V20a2 2 0 0 0-2-2H26a2 2 0 0 0-2 2v2H16V14h6a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H6A2 2 0 0 0 4 4v8a2 2 0 0 0 2 2h6V40a2 2 0 0 0 2 2H24v2a2 2 0 0 0 2 2H42a2 2 0 0 0 2-2V36a2 2 0 0 0-2-2H26a2 2 0 0 0-2 2v2H16V26h8v2a2 2 0 0 0 2 2Z"/>
                </Viewbox>
                <TextBlock x:Name="txtTitle" Text="Model Management"
                           FontSize="26" FontWeight="Bold" Foreground="#4A4A4A" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="btnMoreFilter" Style="{StaticResource IconActionBtn}"
                        Width="150" Margin="0,0,10,0" Click="BtnMoreFilter_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Line X1="3" Y1="5" X2="21" Y2="5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="3" Y1="12" X2="15" Y2="12"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="3" Y1="19" X2="11" Y2="19"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Grid.Column="1" Text="More Filter" VerticalAlignment="Center" FontSize="14"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource IconActionBtn}" Width="160" Click="BtnAddModel_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M12 5 L12 19 M5 12 L19 12"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Grid.Column="1" Text="Add Model" VerticalAlignment="Center" FontSize="14"/>
                    </Grid>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- SEARCH + WAREHOUSE -->
        <Grid Grid.Row="1" VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Height="65">
                <Border CornerRadius="12" Background="White" BorderBrush="#CED6E0" BorderThickness="1"/>
                <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" FontSize="14" Padding="35,0,5,0"
                         Foreground="#2F3640" TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder" Text=" Search model..."
                           Foreground="#A4B0BE" VerticalAlignment="Center"
                           FontSize="16" Margin="35,0,5,0" IsHitTestVisible="False"/>
                <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="10,0,0,0" FontSize="16" Foreground="#57606f"/>
            </Grid>

            <!-- STATUS FILTER COMBOBOX -->
            <ComboBox x:Name="cmbStatus"
                       Grid.Column="2"
                       Style="{StaticResource ModernComboBox}"
                       ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                       HorizontalAlignment="Right"
                       Width="220"
                       Height="45"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       Cursor="Hand"
                       SelectionChanged="cmbStatus_SelectionChanged">
                <ComboBoxItem Content="All Brands" Tag="all"/>
                <ComboBoxItem Content="Active" Tag="active"/>
                <ComboBoxItem Content="Not Active" Tag="inactive"/>
            </ComboBox>

        </Grid>

        <!-- CARDS AREA — filter panel floats on top as overlay -->
        <Grid Grid.Row="3">

            <!-- Cards (full width, untouched) -->
            <ScrollViewer x:Name="CardScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          ClipToBounds="True">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb x:Name="Thumb">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Rectangle Fill="#9CA3AF" RadiusX="3" RadiusY="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="False">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <Grid>
                    <ItemsControl x:Name="DynamicCardContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="WrapPanelContainer" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <TextBlock x:Name="NoModelsMessage"
                               Foreground="Gray" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- LOADING OVERLAY -->
            <Grid x:Name="LoadingOverlay" Background="#F5F5F5" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="80" Height="80">
                        <Ellipse Width="60" Height="60" Stroke="#E0E0E0" StrokeThickness="6"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="100" Height="100">
                                <Path Stroke="#4A4A4A" StrokeThickness="10"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="50,10">
                                                <ArcSegment Point="10,50" Size="40,40"
                                                            SweepDirection="Clockwise" IsLargeArc="True"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" CenterX="50" CenterY="50" Angle="0"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360" Duration="0:0:0.8"
                                                                     RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                    <TextBlock Text="Loading models..." Foreground="#4A4A4A" FontWeight="SemiBold"
                               FontSize="14" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- FLOATING FILTER PANEL — overlays cards, top-right, fixed width -->
            <Border x:Name="FilterPanel"
                    Width="220"
                    MaxHeight="300"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,20,0"
                    Panel.ZIndex="10"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#DDE1E8"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    Opacity="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#F8F9FA" CornerRadius="14,14,0,0"
                            BorderBrush="#DDE1E8" BorderThickness="0,0,0,1">
                        <Grid Margin="14,0">
                            <TextBlock Text="Filter" FontSize="13" FontWeight="Bold"
                                       Foreground="#2C3E50" VerticalAlignment="Center"/>
                            <Button x:Name="btnCloseFilter" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Width="26" Height="26"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="BtnCloseFilter_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#ECECEC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path Fill="#999" Stretch="Uniform" Width="9" Height="9"
                                      Data="M18.3 5.71L12 12l6.3 6.29-1.41 1.42L10.59 13.4l-6.3 6.31-1.41-1.42L9.17 12 2.88 5.71l1.41-1.42 6.3 6.3 6.29-6.3z"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Filters -->
                    <StackPanel Grid.Row="1" Margin="14,10">
                        <TextBlock Text="Brand" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#6B7280" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbFilterBrand"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                                  HorizontalAlignment="Stretch" Cursor="Hand"
                                  Margin="0,0,0,10"
                                  SelectionChanged="cmbFilterBrand_SelectionChanged">
                            <ComboBoxItem Content="All Brands" IsSelected="True"/>
                        </ComboBox>

                        <TextBlock Text="Series" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#6B7280" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbFilterSeries"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                                  HorizontalAlignment="Stretch" Cursor="Hand"
                                  SelectionChanged="cmbFilterSeries_SelectionChanged">
                            <ComboBoxItem Content="All Series" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Apply / Clear -->
                    <Border Grid.Row="2" BorderBrush="#DDE1E8" BorderThickness="0,1,0,0" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="btnClearFilter"
                Height="34" Background="#F3F4F6" Foreground="#374151"
                FontWeight="SemiBold" FontSize="12" Cursor="Hand"
                BorderThickness="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="BtnClearFilter_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Clear" VerticalAlignment="Center"/>
                            </Button>

                            <Button Grid.Column="2" x:Name="btnApplyFilter"
                Height="34" Background="#FF8C42" Foreground="White"
                FontWeight="SemiBold" FontSize="12" Cursor="Hand"
                BorderThickness="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="BtnApplyFilter_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Apply" VerticalAlignment="Center"/>
                            </Button>

                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>

        <!-- TOTAL MODELS -->
        <Border Grid.Row="4" Margin="0,10,10,10" Background="White" CornerRadius="8"
                Padding="12" HorizontalAlignment="Left" VerticalAlignment="Center"
                Effect="{StaticResource DropShadow}">
            <TextBlock x:Name="txtTotalModels" Text="Total Models: 0"
                       FontSize="16" FontWeight="SemiBold" Foreground="#2C3E50"/>
        </Border>

    </Grid>
</UserControl>
