<UserControl x:Class="POS_WPF.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged"
             >
    <UserControl.Resources>

        <!-- Shadow card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat label -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            
        </Style>

        <!-- Stat value -->
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D23"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Section title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D23"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Table header cell -->
        <Style x:Key="TableHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9099A8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Table value cell -->
        <Style x:Key="TableCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2D3142"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- KPI Cards -->
                <RowDefinition Height="Auto"/>
                <!-- Chart + Low Stock -->
                <RowDefinition Height="Auto"/>
                <!-- Recent Sales -->
            </Grid.RowDefinitions>

            <!-- ── PAGE HEADER ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Dashboard"
                           FontSize="26" FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Foreground="#1A1D23"/>
                <TextBlock x:Name="txtDate"
                           FontSize="13" Foreground="#9099A8"
                           FontFamily="Segoe UI"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ── KPI CARDS ── -->
            <UniformGrid x:Name="StatsGrid" Grid.Row="1" Columns="4" Margin="0,0,0,20">

                <!-- Products -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOTAL PRODUCTS" Style="{StaticResource StatLabel}"/>
                            <TextBlock x:Name="txtProducts" Style="{StaticResource StatValue}"/>
                            <TextBlock x:Name="txtProductsSub"
                           FontSize="11" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                    Width="44" Height="44" CornerRadius="22"
                    Background="#FFF3EA" VerticalAlignment="Top">
                            <Path Data="M20,4H4C2.9,4,2,4.9,2,6v2h20V6C22,4.9,21.1,4,20,4z M2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2v-8H2V18z"
                      Fill="#FF8C42" Width="20" Height="18"
                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Sales -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOTAL SALES" Style="{StaticResource StatLabel}"/>
                            <TextBlock x:Name="txtSales" Style="{StaticResource StatValue}"/>
                            <TextBlock x:Name="txtSalesSub"
                           FontSize="11" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                    Width="44" Height="44" CornerRadius="22"
                    Background="#E8F5E9" VerticalAlignment="Top">
                            <Path Data="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM7.2 14.8l.1-.4.9-1.6H17c.75 0 1.41-.41 1.75-1.03l3.24-5.88A1 1 0 0 0 21.12 4H5.21l-.94-2H1v2h2l3.6 7.59L5.25 14c-.16.28-.25.61-.25.93C5 16.1 5.9 17 7 17h14v-2H7.42c-.13 0-.22-.11-.22-.22z"
                      Fill="#43A047" Width="20" Height="20"
                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Revenue -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOTAL REVENUE" Style="{StaticResource StatLabel}"/>
                            <TextBlock x:Name="txtRevenue" Style="{StaticResource StatValue}"/>
                            <TextBlock x:Name="txtRevenueSub"
                           FontSize="11" Foreground="#9099A8"
                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                    Width="44" Height="44" CornerRadius="22"
                    Background="#E3F2FD" VerticalAlignment="Top">
                            <Path Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"
                      Fill="#1E88E5" Width="20" Height="20"
                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Low Stock -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LOW STOCK ITEMS" Style="{StaticResource StatLabel}"/>
                            <TextBlock x:Name="txtLowStock" Style="{StaticResource StatValue}" Foreground="#E53935"/>
                            <TextBlock Text="Needs attention"
                           FontSize="11" Foreground="#E53935"
                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                    Width="44" Height="44" CornerRadius="22"
                    Background="#FFEBEE" VerticalAlignment="Top">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                      Fill="#E53935" Width="20" Height="20"
                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

            </UniformGrid>
            <!-- ── CHART + LOW STOCK SIDE PANEL ── -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart Card -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sales — Last 7 Days"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="txtChartTotal"
                                       FontSize="12" Foreground="#9099A8"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Chart Area -->
                        <Canvas x:Name="ChartCanvas" Height="180" ClipToBounds="False"/>
                        <!-- X-axis labels -->
                        <Grid x:Name="ChartLabels" Margin="40,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock Alerts -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Ellipse Width="8" Height="8" Fill="#E53935"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Low Stock Alerts"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LowStockPanel"/>
                        </ScrollViewer>
                        <TextBlock x:Name="txtNoLowStock"
                                   Text="✓  All items well stocked"
                                   FontSize="12" Foreground="#43A047"
                                   FontFamily="Segoe UI"
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── RECENT SALES ── -->
            <Border Grid.Row="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Recent Sales" Style="{StaticResource SectionTitle}"/>

                    <!-- Table Header -->
                    <Border Background="#F8F9FB" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SALE ID"  Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="1" Text="CLIENT"   Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="2" Text="DATE"     Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="3" Text="TOTAL"    Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl x:Name="RecentSalesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" BorderBrush="#F0F0F5" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SaleID}"    Style="{StaticResource TableCell}" Foreground="#9099A8"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Client}"    Style="{StaticResource TableCell}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SaleDate}"  Style="{StaticResource TableCell}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Total}"     Style="{StaticResource TableCell}" HorizontalAlignment="Right" Foreground="#FF8C42" FontWeight="SemiBold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="txtNoSales"
                               Text="No recent sales found."
                               FontSize="12" Foreground="#9099A8"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,20"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>